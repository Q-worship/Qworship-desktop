{
  "name": "qworship-v2-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" run dev",
    "dev:desktop": "pnpm --filter \"@qworship/client\" run dev:desktop",
    "build": "pnpm --filter \"./apps/*\" run build",
    "build:desktop": "pnpm --filter \"@qworship/client\" run build:desktop",
    "lint": "pnpm --filter \"*\" run lint"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "ffi-napi": "npm:@tigerconnect/ffi-napi@4.0.3-tc3",
      "ref-napi": "npm:@tigerconnect/ref-napi@4.0.0-tc8"
    }
  }
}
