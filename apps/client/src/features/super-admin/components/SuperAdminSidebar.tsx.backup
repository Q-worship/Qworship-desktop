                    <SelectItem value="paid" className={isDarkMode ? 'text-gray-100 hover:bg-gray-700' : 'text-gray-900 hover:bg-gray-100'}>Paid</SelectItem>
                    <SelectItem value="failed" className={isDarkMode ? 'text-gray-100 hover:bg-gray-700' : 'text-gray-900 hover:bg-gray-100'}>Failed</SelectItem>
                  </SelectContent>
                </Select>
                
                <Select value={cycleFilter} onValueChange={setCycleFilter}>
                  <SelectTrigger className={themeClasses.selectTrigger}>
                    <span className={isDarkMode ? 'text-gray-100' : 'text-gray-900'}>
                      {(() => {
