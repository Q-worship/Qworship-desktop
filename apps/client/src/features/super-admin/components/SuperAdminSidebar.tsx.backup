                    </div>
                    <div className={`w-full h-2 rounded-full ${isDarkMode ? 'bg-gray-700' : 'bg-gray-200'}`}>
                      <div className="w-[28%] h-2 rounded-full bg-gradient-to-r from-green-500 to-green-600"></div>
                    </div>
                  </div>

                  <div>
                    <div className="flex items-center justify-between mb-2">
                      <span className={`text-sm ${themeClasses.primaryText}`}>Tech Team Members</span>
                      <span className={`text-sm font-medium ${themeClasses.primaryText}`}>7%</span>
                    </div>
                    <div className={`w-full h-2 rounded-full ${isDarkMode ? 'bg-gray-700' : 'bg-gray-200'}`}>
                      <div className="w-[7%] h-2 rounded-full bg-gradient-to-r from-purple-500 to-purple-600"></div>
                    </div>
                  </div>
                </div>
              </div>

              <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-gray-700 bg-gradient-to-br from-green-900/20 to-blue-900/20 backdrop-blur-sm' : 'border-gray-200 bg-gradient-to-br from-green-50/50 to-blue-50/50'}`}>
                <h3 className={`font-semibold ${themeClasses.primaryText} text-lg mb-6`}>Recent User Activity</h3>
                <div className="space-y-4">
                  <div className={`p-3 rounded-lg border ${isDarkMode ? 'border-blue-700/30 bg-blue-900/10' : 'border-blue-200 bg-blue-50'}`}>
                    <div className="flex items-center gap-3">
                      <div className={`p-1 rounded-full ${isDarkMode ? 'bg-blue-600/20 text-blue-400' : 'bg-blue-100 text-blue-600'}`}>
                        <UserPlus className="h-3 w-3" />
                      </div>
                      <div className="flex-1">
                        <div className={`text-sm font-medium ${themeClasses.primaryText}`}>New Registration</div>
                        <div className={`text-xs ${themeClasses.secondaryText}`}>Grace Baptist Church - 2 hours ago</div>
                      </div>
                    </div>
                  </div>

                  <div className={`p-3 rounded-lg border ${isDarkMode ? 'border-green-700/30 bg-green-900/10' : 'border-green-200 bg-green-50'}`}>
                    <div className="flex items-center gap-3">
                      <div className={`p-1 rounded-full ${isDarkMode ? 'bg-green-600/20 text-green-400' : 'bg-green-100 text-green-600'}`}>
                        <Activity className="h-3 w-3" />
                      </div>
                      <div className="flex-1">
                        <div className={`text-sm font-medium ${themeClasses.primaryText}`}>Active Session</div>
                        <div className={`text-xs ${themeClasses.secondaryText}`}>St. Mark's Anglican - Live presentation</div>
                      </div>
                    </div>
                  </div>

                  <div className={`p-3 rounded-lg border ${isDarkMode ? 'border-purple-700/30 bg-purple-900/10' : 'border-purple-200 bg-purple-50'}`}>
                    <div className="flex items-center gap-3">
                      <div className={`p-1 rounded-full ${isDarkMode ? 'bg-purple-600/20 text-purple-400' : 'bg-purple-100 text-purple-600'}`}>
                        <Mic className="h-3 w-3" />
                      </div>
                      <div className="flex-1">
                        <div className={`text-sm font-medium ${themeClasses.primaryText}`}>Voice Command Used</div>
                        <div className={`text-xs ${themeClasses.secondaryText}`}>First Presbyterian - Bible navigation</div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            {/* User Management Table */}
            <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-gray-700 bg-gradient-to-br from-gray-900/30 to-gray-800/20 backdrop-blur-sm' : 'border-gray-200 bg-gradient-to-br from-gray-50/50 to-white/50'}`}>
              <div className="flex items-center justify-between mb-6">
                <div>
                  <h3 className={`font-semibold ${themeClasses.primaryText} text-lg mb-2`}>User Management</h3>
                  <p className={`text-sm ${themeClasses.secondaryText}`}>Manage all Q-worship users with comprehensive controls and real-time updates</p>
                </div>
                <div className="flex items-center gap-3">
                  <div className="flex items-center gap-2">
                    <Search className={`h-4 w-4 ${themeClasses.secondaryText}`} />
                    <input
                      type="text"
                      placeholder="Search users..."
                      value={searchTerm}
                      onChange={(e) => setSearchTerm(e.target.value)}
                      className={`px-3 py-2 rounded border text-sm w-48 ${isDarkMode ? 'bg-gray-700 border-gray-600 text-gray-100 placeholder-gray-400' : 'bg-white border-gray-300 text-gray-900 placeholder-gray-500'}`}
                    />
                  </div>
                  <Select value={userFilter} onValueChange={setUserFilter}>
                    <SelectTrigger className={`w-32 ${themeClasses.selectTrigger}`}>
                      <SelectValue />
                    </SelectTrigger>
                    <SelectContent className={themeClasses.selectContent}>
                      <SelectItem value="all">All Users</SelectItem>
                      <SelectItem value="active">Active</SelectItem>
                      <SelectItem value="trial">Trial</SelectItem>
                      <SelectItem value="paid">Paid</SelectItem>
                      <SelectItem value="suspended">Suspended</SelectItem>
                      <SelectItem value="archived">Archived</SelectItem>
                    </SelectContent>
                  </Select>
                </div>
              </div>

              {/* Table Header */}
              <div className={`grid grid-cols-12 gap-4 p-4 rounded-t-lg border-b font-medium text-sm ${isDarkMode ? 'bg-gray-800/50 border-gray-600 text-gray-300' : 'bg-gray-100/50 border-gray-200 text-gray-600'}`}>
                <div className="col-span-3">User</div>
                <div className="col-span-2">Organization</div>
                <div className="col-span-2">Plan</div>
                <div className="col-span-2">Status</div>
                <div className="col-span-2">Last Active</div>
                <div className="col-span-1">Actions</div>
              </div>

              {/* Table Rows */}
              <div className="space-y-0">
                {[
                  {
                    id: 1,
                    name: 'Sarah Johnson',
                    email: 'sarah@gracechurch.org',
                    organization: 'Grace Community Church',
                    plan: 'Premium',
                    status: 'Active',
                    lastActive: '2 hours ago',
                    avatar: 'SJ'
                  },
                  {
                    id: 2,
                    name: 'Michael Chen',
