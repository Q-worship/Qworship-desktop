                </h3>
                <div className="space-y-4">
                  <div className={`flex items-center justify-between p-4 rounded-lg border transition-colors ${isDarkMode ? 'border-slate-600/40 bg-slate-800/30 hover:bg-slate-800/50' : 'border-gray-200 bg-white/50 hover:bg-gray-50'}`}>
                    <div>
                      <div className={`font-medium ${themeClasses.primaryText}`}>Default Plan Selection</div>
                      <div className={`text-sm ${themeClasses.secondaryText} opacity-80`}>Pre-selected plan in onboarding</div>
                    </div>
                    <Select>
                      <SelectTrigger className={`w-32 ${themeClasses.selectTrigger}`}>
                        <SelectValue placeholder="Professional" />
                      </SelectTrigger>
                      <SelectContent className={themeClasses.selectContent}>
                        <SelectItem value="trial">Free Trial</SelectItem>
                        <SelectItem value="basic">Basic</SelectItem>
                        <SelectItem value="professional">Professional</SelectItem>
                        <SelectItem value="enterprise">Enterprise</SelectItem>
                      </SelectContent>
                    </Select>
                  </div>

                  <div className={`flex items-center justify-between p-4 rounded-lg border transition-colors ${isDarkMode ? 'border-slate-600/40 bg-slate-800/30 hover:bg-slate-800/50' : 'border-gray-200 bg-white/50 hover:bg-gray-50'}`}>
                    <div>
                      <div className={`font-medium ${themeClasses.primaryText}`}>Skip Trial Option</div>
                      <div className={`text-sm ${themeClasses.secondaryText} opacity-80`}>Allow direct paid signup</div>
                    </div>
                    <div className="flex items-center">
                      <label className="relative inline-flex items-center cursor-pointer">
                        <input 
                          type="checkbox" 
                          className="sr-only peer" 
                          defaultChecked 
                          onChange={(e) => {
                            console.log('Skip trial option:', e.target.checked);
                            // Add toggle functionality here
                          }}
                        />
                        <div className={`w-11 h-6 rounded-full peer transition-colors ${isDarkMode ? 'bg-gray-700 peer-checked:bg-purple-600' : 'bg-gray-200 peer-checked:bg-purple-600'} peer-focus:outline-none peer-focus:ring-4 ${isDarkMode ? 'peer-focus:ring-purple-800' : 'peer-focus:ring-purple-300'} relative`}>
                          <div className={`absolute top-[2px] left-[2px] bg-white border border-gray-300 rounded-full h-5 w-5 transition-transform peer-checked:translate-x-full peer-checked:border-white`}></div>
                        </div>
                      </label>
                    </div>
                  </div>

                  <div className={`flex items-center justify-between p-4 rounded-lg border transition-colors ${isDarkMode ? 'border-slate-600/40 bg-slate-800/30 hover:bg-slate-800/50' : 'border-gray-200 bg-white/50 hover:bg-gray-50'}`}>
                    <div>
                      <div className={`font-medium ${themeClasses.primaryText}`}>Payment Collection</div>
                      <div className={`text-sm ${themeClasses.secondaryText} opacity-80`}>When to collect payment info</div>
                    </div>
                    <Select>
                      <SelectTrigger className={`w-32 ${themeClasses.selectTrigger}`}>
                        <SelectValue placeholder="Trial End" />
                      </SelectTrigger>
                      <SelectContent className={themeClasses.selectContent}>
                        <SelectItem value="immediate">Immediate</SelectItem>
                        <SelectItem value="trial-end">Trial End</SelectItem>
                        <SelectItem value="optional">Optional</SelectItem>
                      </SelectContent>
                    </Select>
                  </div>

                  <div className={`flex items-center justify-between p-4 rounded-lg border transition-colors ${isDarkMode ? 'border-slate-600/40 bg-slate-800/30 hover:bg-slate-800/50' : 'border-gray-200 bg-white/50 hover:bg-gray-50'}`}>
                    <div>
                      <div className={`font-medium ${themeClasses.primaryText}`}>Plan Comparison</div>
                      <div className={`text-sm ${themeClasses.secondaryText} opacity-80`}>Show detailed plan comparison</div>
                    </div>
                    <div className="flex items-center">
                      <label className="relative inline-flex items-center cursor-pointer">
                        <input 
                          type="checkbox" 
                          className="sr-only peer" 
                          defaultChecked 
                          onChange={(e) => {
                            console.log('Plan comparison:', e.target.checked);
                            // Add toggle functionality here
                          }}
                        />
                        <div className={`w-11 h-6 rounded-full peer transition-colors ${isDarkMode ? 'bg-gray-700 peer-checked:bg-purple-600' : 'bg-gray-200 peer-checked:bg-purple-600'} peer-focus:outline-none peer-focus:ring-4 ${isDarkMode ? 'peer-focus:ring-purple-800' : 'peer-focus:ring-purple-300'} relative`}>
                          <div className={`absolute top-[2px] left-[2px] bg-white border border-gray-300 rounded-full h-5 w-5 transition-transform peer-checked:translate-x-full peer-checked:border-white`}></div>
                        </div>
                      </label>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            {/* Plan Analytics and Performance */}
            <div className={`p-6 rounded-xl border transition-all duration-300 ${isDarkMode ? 'border-emerald-600/40 bg-gradient-to-br from-emerald-900/30 to-emerald-800/20 backdrop-blur-lg shadow-xl' : 'border-gray-200 bg-gradient-to-br from-gray-50/50 to-white/50'}`}>
              <h3 className={`font-semibold ${themeClasses.primaryText} text-lg mb-6 flex items-center gap-2`}>
                <BarChart3 className={`h-5 w-5 ${isDarkMode ? 'text-emerald-400' : 'text-emerald-600'}`} />
                Plan Performance Analytics
              </h3>
              <div className="grid grid-cols-1 md:grid-cols-4 gap-6">
                <div className={`text-center p-4 rounded-lg transition-all duration-300 ${isDarkMode ? 'bg-slate-800/40 border border-slate-700/50 hover:bg-slate-800/60' : 'bg-white/50 border border-gray-200 hover:shadow-md'}`}>
                  <div className={`text-2xl font-bold ${themeClasses.primaryText} mb-1`}>£68,420</div>
                  <div className={`text-sm ${themeClasses.secondaryText} opacity-80`}>Monthly Recurring Revenue</div>
                  <div className={`text-xs ${isDarkMode ? 'text-green-400' : 'text-green-600'} flex items-center justify-center gap-1 mt-2 font-medium`}>
                    <TrendingUp className="h-3 w-3" />
                    +12.4% vs last month
                  </div>
                </div>
                <div className={`text-center p-4 rounded-lg transition-all duration-300 ${isDarkMode ? 'bg-slate-800/40 border border-slate-700/50 hover:bg-slate-800/60' : 'bg-white/50 border border-gray-200 hover:shadow-md'}`}>
                  <div className={`text-2xl font-bold ${themeClasses.primaryText} mb-1`}>892</div>
                  <div className={`text-sm ${themeClasses.secondaryText} opacity-80`}>Active Subscriptions</div>
                  <div className={`text-xs ${isDarkMode ? 'text-green-400' : 'text-green-600'} flex items-center justify-center gap-1 mt-2 font-medium`}>
                    <TrendingUp className="h-3 w-3" />
                    +18.2% vs last month
                  </div>
                </div>
                <div className={`text-center p-4 rounded-lg transition-all duration-300 ${isDarkMode ? 'bg-slate-800/40 border border-slate-700/50 hover:bg-slate-800/60' : 'bg-white/50 border border-gray-200 hover:shadow-md'}`}>
                  <div className={`text-2xl font-bold ${themeClasses.primaryText} mb-1`}>24.8%</div>
                  <div className={`text-sm ${themeClasses.secondaryText} opacity-80`}>Trial Conversion Rate</div>
                  <div className={`text-xs ${isDarkMode ? 'text-orange-400' : 'text-orange-600'} flex items-center justify-center gap-1 mt-2 font-medium`}>
                    <TrendingDown className="h-3 w-3" />
                    -2.1% vs last month
                  </div>
                </div>
                <div className={`text-center p-4 rounded-lg transition-all duration-300 ${isDarkMode ? 'bg-slate-800/40 border border-slate-700/50 hover:bg-slate-800/60' : 'bg-white/50 border border-gray-200 hover:shadow-md'}`}>
                  <div className={`text-2xl font-bold ${themeClasses.primaryText} mb-1`}>£76.70</div>
                  <div className={`text-sm ${themeClasses.secondaryText} opacity-80`}>Average Revenue Per User</div>
                  <div className={`text-xs ${isDarkMode ? 'text-green-400' : 'text-green-600'} flex items-center justify-center gap-1 mt-2 font-medium`}>
                    <TrendingUp className="h-3 w-3" />
                    +5.9% vs last month
                  </div>
                </div>
              </div>
            </div>
          </CardContent>
        </Card>
        </>
      );
    }

    // For other sections, show a placeholder for now
    return (
      <Card className={themeClasses.analyticsCard}>
        <CardHeader>
          <CardTitle className={themeClasses.primaryText}>
            {sidebarItems.flatMap(s => s.items).find(item => item.id === activeSection)?.label || 'Section'}
          </CardTitle>
          <CardDescription className={themeClasses.secondaryText}>
            Detailed analytics and management for {sidebarItems.flatMap(s => s.items).find(item => item.id === activeSection)?.description}
          </CardDescription>
        </CardHeader>
        <CardContent>
          <div className="text-center py-8">
            <div className={`text-lg ${themeClasses.secondaryText} mb-4`}>
              This section is being developed with comprehensive business functionality tracking.
            </div>
            <div className={`text-sm ${themeClasses.secondaryText}`}>
              All user actions are automatically tracked and will be displayed here with detailed analytics.
            </div>
          </div>
        </CardContent>
      </Card>
    );
  };

  return (
    <div className={`h-screen ${themeClasses.background} font-sans flex flex-col overflow-hidden`}>
      {/* Top Bar */}
      <AdminTopBar
        isDarkMode={isDarkMode}
        toggleTheme={toggleTheme}
        dateRange={dateRange}
        setDateRange={setDateRange}
        onExportData={exportData}
        searchTerm={searchTerm}
        setSearchTerm={setSearchTerm}
        activeSection={activeSection}
        setActiveSection={setActiveSection}
      />
      
      <div className="flex flex-1 overflow-hidden">
        {/* Sidebar */}
        <div className={`w-80 ${themeClasses.sidebarBackground} border-r ${themeClasses.border} flex-shrink-0 flex flex-col`}>
          {/* Sidebar Header */}
          <div className={`${themeClasses.headerBackground} border-b ${themeClasses.border} p-6 flex-shrink-0`}>
            <div className="flex items-center space-x-3">
              <div>
                <span className={`text-lg font-bold [font-family:'Lufga-Medium',Helvetica] ${themeClasses.primaryText}`}>
                  SuperAdmin Portal
                </span>
                <p className={`text-sm ${themeClasses.secondaryText}`}>Management Dashboard</p>
              </div>
            </div>
          </div>

          {/* Sidebar Navigation */}
          <div className="flex-1 overflow-y-auto">
            <div className="p-4 space-y-6">
              {sidebarItems.map((section, index) => (
                <div key={index}>
                  <h3 className={`text-xs font-semibold uppercase tracking-wider mb-3 ${themeClasses.sectionHeader}`}>
                    {section.section}
                  </h3>
                  <div className="space-y-1">
                    {section.items.map((item) => {
                      const Icon = item.icon;
                      const isActive = activeSection === item.id && !showUserProfile;
                      return (
                        <button
                          key={item.id}
                          onClick={() => {
                            setActiveSection(item.id);
                            setShowUserProfile(false);
                            setProfileUserId(null);
                          }}
                          className={`w-full flex items-center px-3 py-2 rounded-lg text-left transition-all duration-200 group ${
                            isActive 
                              ? `${themeClasses.activeSidebarItem} shadow-sm` 
                              : `${themeClasses.inactiveSidebarItem} hover:${themeClasses.hoverSidebarItem}`
                          }`}
                        >
                          <Icon className={`h-4 w-4 mr-3 flex-shrink-0 ${
                            isActive ? themeClasses.activeSidebarIcon : themeClasses.inactiveSidebarIcon
                          }`} />
                          <div className="flex-1 min-w-0">
                            <div className={`text-sm font-medium [font-family:'Lufga-Medium',Helvetica] ${
                              isActive ? themeClasses.activeSidebarText : themeClasses.inactiveSidebarText
                            }`}>
                              {item.label}
                            </div>
                            <div className={`text-xs truncate ${
                              isActive ? themeClasses.activeSidebarSubtext : themeClasses.inactiveSidebarSubtext
                            }`}>
                              {item.description}
                            </div>
                          </div>
                        </button>
                      );
                    })}
                  </div>
                </div>
              ))}
            </div>
          </div>

          {/* Sidebar Footer */}
          <div className={`border-t ${themeClasses.border} p-4 flex-shrink-0`}>
            <Button
              variant="ghost" 
              size="sm"
              className={`w-full justify-start ${themeClasses.button}`}
              onClick={() => window.location.href = '/'}
            >
              <LogOut className="h-4 w-4 mr-2" />
              Exit SuperAdmin
            </Button>
          </div>
        </div>

        {/* Main Content Area */}
        <div className="flex-1 flex flex-col overflow-hidden">
          {/* Section Header */}
          <div className={`${themeClasses.headerBackground} border-b ${themeClasses.border} px-6 py-4 flex-shrink-0`}>
            <div className="flex items-center justify-between">
              <div>
                <h1 className={`text-2xl font-bold [font-family:'Lufga-Medium',Helvetica] ${themeClasses.primaryText}`}>
                  {showUserProfile ? 'User Profile' : sidebarItems.flatMap(s => s.items).find(item => item.id === activeSection)?.label || 'Dashboard'}
                </h1>
                <p className={`mt-1 ${themeClasses.secondaryText}`}>
                  {showUserProfile ? 'Comprehensive user profile and management' : sidebarItems.flatMap(s => s.items).find(item => item.id === activeSection)?.description || 'Comprehensive analytics and management'}
                </p>
              </div>
            </div>
          </div>

          {/* Main Content */}
          <div className="flex-1 overflow-y-auto p-6">
            {isLoading ? (
              <div className="grid grid-cols-1 md:grid-cols-4 gap-6">
                {[1, 2, 3, 4].map((i) => (
                  <Card key={i} className={`animate-pulse ${themeClasses.cardBackground}`}>
                    <CardHeader className="pb-2">
                      <div className={`h-4 rounded w-3/4 ${isDarkMode ? 'bg-gray-700' : 'bg-gray-300'}`}></div>
                    </CardHeader>
                    <CardContent>
                      <div className={`h-8 rounded w-1/2 mb-2 ${isDarkMode ? 'bg-gray-700' : 'bg-gray-300'}`}></div>
                      <div className={`h-3 rounded w-full ${isDarkMode ? 'bg-gray-700' : 'bg-gray-300'}`}></div>
                    </CardContent>
                  </Card>
                ))}
              </div>
            ) : (
              renderMainContent()
            )}
          </div>
        </div>
      </div>
      
      {/* Render Funnel Popup */}
      {renderFunnelPopup()}
    </div>
  );
}


