                  <div className={`flex-1 h-2 rounded-full ${isDarkMode ? 'bg-gray-700/60' : 'bg-gray-200'}`}>
                    <div className={`w-[10%] h-2 rounded-full ${isDarkMode ? 'bg-gradient-to-r from-amber-400 to-amber-500' : 'bg-amber-500'}`}></div>
                  </div>
                  <span className={`text-xs ${themeClasses.secondaryText} font-medium`}>10%</span>
                </div>
