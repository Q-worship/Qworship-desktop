                    <div className={`w-full h-2 rounded-full ${isDarkMode ? 'bg-gray-700' : 'bg-gray-200'} mb-2`}>
                      <div className="w-[22%] h-2 rounded-full bg-gradient-to-r from-blue-500 to-blue-600"></div>
                    </div>
                    <div className={`text-xs ${themeClasses.secondaryText}`}>
                      £15/month - Core features
                    </div>
                  </div>

                  <div className={`p-4 rounded-lg border ${isDarkMode ? 'border-purple-700/30 bg-purple-900/10' : 'border-purple-200 bg-purple-50'}`}>
