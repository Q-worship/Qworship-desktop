  // Generate realistic chart data based on current metrics and grouping
  const generateChartData = (): ChartData[] => {
    const data: ChartData[] = [];
    const startDate = new Date();
    const totalDays = chartDateRange === '7d' ? 7 : chartDateRange === '30d' ? 30 : chartDateRange === '90d' ? 90 : 365;
    startDate.setDate(startDate.getDate() - totalDays);
    
    // Calculate intervals based on grouping
    let intervalCount: number;
    let intervalDays: number;
    const showComparison = ['week', 'month', 'quarter', 'year'].includes(chartGroupBy);
    
    switch (chartGroupBy) {
      case 'day':
        intervalCount = Math.min(totalDays, 30); // Max 30 bars for daily view
        intervalDays = Math.max(1, Math.floor(totalDays / intervalCount));
        break;
      case 'week':
        intervalCount = showComparison ? Math.min(8, Math.max(2, Math.floor(totalDays / 7))) : Math.max(1, Math.floor(totalDays / 7));
        intervalDays = 7;
        break;
      case 'month':
        intervalCount = showComparison ? Math.min(6, Math.max(2, Math.floor(totalDays / 30))) : Math.max(1, Math.floor(totalDays / 30));
        intervalDays = 30;
        break;
      case 'quarter':
        intervalCount = showComparison ? Math.min(4, Math.max(2, Math.floor(totalDays / 90))) : Math.max(1, Math.floor(totalDays / 90));
        intervalDays = 90;
        break;
      case 'year':
        intervalCount = showComparison ? Math.min(3, Math.max(2, Math.floor(totalDays / 365))) : Math.max(1, Math.floor(totalDays / 365));
        intervalDays = 365;
        break;
      default:
        intervalCount = Math.min(totalDays, 30);
        intervalDays = Math.max(1, Math.floor(totalDays / intervalCount));
    }
    
    for (let i = 0; i < intervalCount; i++) {
      const date = new Date(startDate);
      date.setDate(date.getDate() + (i * intervalDays));
      
      // Generate aggregated data based on interval
      const multiplier = intervalDays;
      const isCurrentPeriod = i === intervalCount - 1; // Last period is current
      
      let dateLabel: string;
      let periodType: 'current' | 'previous' = isCurrentPeriod && showComparison ? 'current' : 'previous';
      
      switch (chartGroupBy) {
        case 'week':
          const weekStart = new Date(date);
          const weekEnd = new Date(date);
          weekEnd.setDate(weekEnd.getDate() + 6);
          if (showComparison) {
            dateLabel = isCurrentPeriod ? 'This Week' : `${intervalCount - i - 1} week${intervalCount - i - 1 > 1 ? 's' : ''} ago`;
          } else {
            dateLabel = `${weekStart.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })} - ${weekEnd.toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}`;
          }
          break;
        case 'month':
          if (showComparison) {
            dateLabel = isCurrentPeriod ? 'This Month' : `${intervalCount - i - 1} month${intervalCount - i - 1 > 1 ? 's' : ''} ago`;
          } else {
            dateLabel = date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
          }
          break;
        case 'quarter':
          const quarter = Math.floor(date.getMonth() / 3) + 1;
          if (showComparison) {
            dateLabel = isCurrentPeriod ? 'This Quarter' : `${intervalCount - i - 1} quarter${intervalCount - i - 1 > 1 ? 's' : ''} ago`;
          } else {
            dateLabel = `Q${quarter} ${date.getFullYear()}`;
          }
          break;
        case 'year':
          if (showComparison) {
            dateLabel = isCurrentPeriod ? 'This Year' : `${intervalCount - i - 1} year${intervalCount - i - 1 > 1 ? 's' : ''} ago`;
          } else {
            dateLabel = date.getFullYear().toString();
          }
          break;
        default:
          dateLabel = date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
          periodType = 'current';
      }
      
      // Generate realistic data with some trend (current period slightly higher)
      const baseUsers = Math.floor((Math.random() * 50 + 20) * multiplier);
      const baseRevenue = Math.floor((Math.random() * 2000 + 500) * multiplier);
      const baseTrials = Math.floor((Math.random() * 15 + 5) * multiplier);
      const baseConversions = Math.floor((Math.random() * 8 + 2) * multiplier);
      
      const currentMultiplier = isCurrentPeriod && showComparison ? 1.1 + (Math.random() * 0.3) : 1;
      
      data.push({
        date: dateLabel,
        users: Math.floor(baseUsers * currentMultiplier),
        revenue: Math.floor(baseRevenue * currentMultiplier),
        trials: Math.floor(baseTrials * currentMultiplier),
        conversions: Math.floor(baseConversions * currentMultiplier),
        period: periodType,
      });
    }
    return data.reverse(); // Show chronologically (oldest to newest)
  };

  // Regional usage data with realistic church demographics
