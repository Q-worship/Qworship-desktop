                    <SelectItem value="30d">Last 30 days</SelectItem>
                    <SelectItem value="90d">Last 90 days</SelectItem>
                    <SelectItem value="1y">Last year</SelectItem>
                  </SelectContent>
                </Select>
                <Button size="sm" variant="outline" onClick={() => exportData('auth-tracking-report')}>
                  <Download className="h-3 w-3 mr-1" />
                  Export
                </Button>
              </div>
            </div>
          </CardHeader>
          
          {/* User Management Navigation Tabs */}
          <div className={`px-6 py-3 border-b ${themeClasses.border}`}>
            <nav className="flex space-x-8" aria-label="User Management Tabs">
              <button
                onClick={() => setActiveSection('users')}
                className={`py-2 px-1 border-b-2 font-medium text-sm flex items-center gap-2 ${
                  activeSection === 'users'
                    ? `border-blue-500 ${isDarkMode ? 'text-blue-400' : 'text-blue-600'}`
                    : `border-transparent ${themeClasses.secondaryText} hover:${themeClasses.primaryText} hover:border-gray-300`
                }`}
              >
                <Users className="h-4 w-4" />
                User Analytics
              </button>
              <button
                onClick={() => setActiveSection('trials')}
                className={`py-2 px-1 border-b-2 font-medium text-sm flex items-center gap-2 ${
                  activeSection === 'trials'
                    ? `border-blue-500 ${isDarkMode ? 'text-blue-400' : 'text-blue-600'}`
                    : `border-transparent ${themeClasses.secondaryText} hover:${themeClasses.primaryText} hover:border-gray-300`
                }`}
              >
                <Clock className="h-4 w-4" />
                Trial Management
              </button>
              <button
                onClick={() => setActiveSection('onboarding')}
                className={`py-2 px-1 border-b-2 font-medium text-sm flex items-center gap-2 ${
                  activeSection === 'onboarding'
                    ? `border-blue-500 ${isDarkMode ? 'text-blue-400' : 'text-blue-600'}`
                    : `border-transparent ${themeClasses.secondaryText} hover:${themeClasses.primaryText} hover:border-gray-300`
                }`}
              >
                <UserCheck className="h-4 w-4" />
                User Onboarding
              </button>
              <button
                onClick={() => setActiveSection('authentication')}
                className={`py-2 px-1 border-b-2 font-medium text-sm flex items-center gap-2 ${
                  activeSection === 'authentication'
                    ? `border-blue-500 ${isDarkMode ? 'text-blue-400' : 'text-blue-600'}`
                    : `border-transparent ${themeClasses.secondaryText} hover:${themeClasses.primaryText} hover:border-gray-300`
                }`}
              >
                <Shield className="h-4 w-4" />
                Auth Tracking
              </button>
            </nav>
          </div>
          
          <CardContent className="space-y-8 pt-6">
            {/* Authentication Metrics */}
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
              <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-green-700/50 bg-gradient-to-br from-green-900/20 to-green-800/10 backdrop-blur-sm' : 'border-green-200 bg-gradient-to-br from-green-50 to-green-100/50'}`}>
                <div className="flex items-center justify-between mb-4">
                  <div className={`p-2 rounded-lg ${isDarkMode ? 'bg-green-600/20 text-green-400' : 'bg-green-100 text-green-600'}`}>
                    <CheckCircle className="h-4 w-4" />
                  </div>
                  <div className={`text-xs ${isDarkMode ? 'text-green-400' : 'text-green-600'} flex items-center gap-1`}>
                    <TrendingUp className="h-3 w-3" />
                    +5.2%
                  </div>
                </div>
                <div>
                  <div className={`text-2xl font-bold ${themeClasses.primaryText} mb-1`}>
                    1,847
                  </div>
                  <div className={`text-sm ${themeClasses.secondaryText}`}>Successful Logins</div>
                  <div className={`text-xs ${themeClasses.secondaryText} mt-2`}>
                    This week
                  </div>
                </div>
              </div>

              <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-red-700/50 bg-gradient-to-br from-red-900/20 to-red-800/10 backdrop-blur-sm' : 'border-red-200 bg-gradient-to-br from-red-50 to-red-100/50'}`}>
                <div className="flex items-center justify-between mb-4">
                  <div className={`p-2 rounded-lg ${isDarkMode ? 'bg-red-600/20 text-red-400' : 'bg-red-100 text-red-600'}`}>
                    <XCircle className="h-4 w-4" />
                  </div>
                  <div className={`text-xs ${isDarkMode ? 'text-red-400' : 'text-red-600'} flex items-center gap-1`}>
                    <TrendingDown className="h-3 w-3" />
                    -12.8%
                  </div>
                </div>
                <div>
                  <div className={`text-2xl font-bold ${themeClasses.primaryText} mb-1`}>
                    47
                  </div>
                  <div className={`text-sm ${themeClasses.secondaryText}`}>Failed Attempts</div>
                  <div className={`text-xs ${themeClasses.secondaryText} mt-2`}>
                    2.5% failure rate
                  </div>
                </div>
              </div>

              <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-orange-700/50 bg-gradient-to-br from-orange-900/20 to-orange-800/10 backdrop-blur-sm' : 'border-orange-200 bg-gradient-to-br from-orange-50 to-orange-100/50'}`}>
                <div className="flex items-center justify-between mb-4">
                  <div className={`p-2 rounded-lg ${isDarkMode ? 'bg-orange-600/20 text-orange-400' : 'bg-orange-100 text-orange-600'}`}>
                    <AlertTriangle className="h-4 w-4" />
                  </div>
                  <div className={`text-xs ${isDarkMode ? 'text-orange-400' : 'text-orange-600'} flex items-center gap-1`}>
                    <TrendingUp className="h-3 w-3" />
                    +8.3%
                  </div>
                </div>
                <div>
                  <div className={`text-2xl font-bold ${themeClasses.primaryText} mb-1`}>
                    12
                  </div>
                  <div className={`text-sm ${themeClasses.secondaryText}`}>Security Alerts</div>
                  <div className={`text-xs ${themeClasses.secondaryText} mt-2`}>
                    Requiring attention
                  </div>
                </div>
              </div>

              <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-blue-700/50 bg-gradient-to-br from-blue-900/20 to-blue-800/10 backdrop-blur-sm' : 'border-blue-200 bg-gradient-to-br from-blue-50 to-blue-100/50'}`}>
                <div className="flex items-center justify-between mb-4">
                  <div className={`p-2 rounded-lg ${isDarkMode ? 'bg-blue-600/20 text-blue-400' : 'bg-blue-100 text-blue-600'}`}>
                    <Globe className="h-4 w-4" />
                  </div>
                  <div className={`text-xs ${isDarkMode ? 'text-green-400' : 'text-green-600'} flex items-center gap-1`}>
                    <TrendingUp className="h-3 w-3" />
                    +15.7%
                  </div>
                </div>
                <div>
                  <div className={`text-2xl font-bold ${themeClasses.primaryText} mb-1`}>
                    342
                  </div>
                  <div className={`text-sm ${themeClasses.secondaryText}`}>Active Sessions</div>
                  <div className={`text-xs ${themeClasses.secondaryText} mt-2`}>
                    Currently logged in
                  </div>
                </div>
              </div>
            </div>

            {/* Authentication Events Timeline */}
            <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-gray-700 bg-gradient-to-br from-gray-900/30 to-gray-800/20 backdrop-blur-sm' : 'border-gray-200 bg-gradient-to-br from-gray-50/50 to-white/50'}`}>
              <div className="flex items-center justify-between mb-6">
                <div>
                  <h3 className={`font-semibold ${themeClasses.primaryText} text-lg mb-2`}>Authentication Events</h3>
                  <p className={`text-sm ${themeClasses.secondaryText}`}>Login attempts, security events, and session activities</p>
                </div>
                <div className="flex items-center gap-2">
                  <Select value={authTimeRange} onValueChange={setAuthTimeRange}>
                    <SelectTrigger className={`w-32 ${themeClasses.selectTrigger}`}>
                      <SelectValue />
                    </SelectTrigger>
                    <SelectContent className={themeClasses.selectContent}>
                      <SelectItem value="24h">Last 24h</SelectItem>
                      <SelectItem value="7d">Last 7 days</SelectItem>
                      <SelectItem value="30d">Last 30 days</SelectItem>
                    </SelectContent>
                  </Select>
                </div>
              </div>

              {/* Authentication Metrics */}
              <div className="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
                <div className={`p-4 rounded-lg border ${isDarkMode ? 'bg-green-900/20 border-green-800' : 'bg-green-50 border-green-200'}`}>
                  <div className={`text-2xl font-bold ${isDarkMode ? 'text-green-300' : 'text-green-600'} mb-1`}>
                    1,247
                  </div>
                  <div className={`text-sm ${isDarkMode ? 'text-green-400' : 'text-green-600'}`}>Successful Logins</div>
                  <div className={`text-xs ${themeClasses.secondaryText} mt-1 flex items-center gap-1`}>
                    <TrendingUp className="h-3 w-3" />
                    +12.4% vs last period
                  </div>
                </div>
                
                <div className={`p-4 rounded-lg border ${isDarkMode ? 'bg-red-900/20 border-red-800' : 'bg-red-50 border-red-200'}`}>
                  <div className={`text-2xl font-bold ${isDarkMode ? 'text-red-300' : 'text-red-600'} mb-1`}>
                    23
                  </div>
                  <div className={`text-sm ${isDarkMode ? 'text-red-400' : 'text-red-600'}`}>Failed Attempts</div>
                  <div className={`text-xs ${themeClasses.secondaryText} mt-1 flex items-center gap-1`}>
                    <TrendingDown className="h-3 w-3" />
                    -8.7% vs last period
                  </div>
                </div>
                
                <div className={`p-4 rounded-lg border ${isDarkMode ? 'bg-blue-900/20 border-blue-800' : 'bg-blue-50 border-blue-200'}`}>
                  <div className={`text-2xl font-bold ${isDarkMode ? 'text-blue-300' : 'text-blue-600'} mb-1`}>
                    892
                  </div>
                  <div className={`text-sm ${isDarkMode ? 'text-blue-400' : 'text-blue-600'}`}>Active Sessions</div>
                  <div className={`text-xs ${themeClasses.secondaryText} mt-1 flex items-center gap-1`}>
                    <TrendingUp className="h-3 w-3" />
                    +5.2% vs last period
                  </div>
                </div>
                
                <div className={`p-4 rounded-lg border ${isDarkMode ? 'bg-orange-900/20 border-orange-800' : 'bg-orange-50 border-orange-200'}`}>
                  <div className={`text-2xl font-bold ${isDarkMode ? 'text-orange-300' : 'text-orange-600'} mb-1`}>
                    6.2m
                  </div>
                  <div className={`text-sm ${isDarkMode ? 'text-orange-400' : 'text-orange-600'}`}>Avg Session Time</div>
                  <div className={`text-xs ${themeClasses.secondaryText} mt-1 flex items-center gap-1`}>
                    <TrendingUp className="h-3 w-3" />
                    +15.8% vs last period
                  </div>
                </div>
              </div>

              {/* Authentication Timeline Chart */}
              <div className="h-64 mb-6">
                <ResponsiveContainer width="100%" height="100%">
                  <LineChart data={authTimelineData}>
                    <CartesianGrid strokeDasharray="3 3" stroke={isDarkMode ? '#374151' : '#e5e7eb'} />
                    <XAxis 
                      dataKey="time" 
                      stroke={isDarkMode ? '#9ca3af' : '#6b7280'}
                      fontSize={12}
                    />
                    <YAxis 
                      stroke={isDarkMode ? '#9ca3af' : '#6b7280'}
                      fontSize={12}
                    />
                    <Tooltip 
                      contentStyle={{
                        backgroundColor: isDarkMode ? '#1f2937' : '#ffffff',
                        border: `1px solid ${isDarkMode ? '#374151' : '#e5e7eb'}`,
                        borderRadius: '8px',
                        color: isDarkMode ? '#f3f4f6' : '#1f2937'
                      }}
                    />
                    <Line 
                      type="monotone" 
                      dataKey="successful" 
                      stroke={isDarkMode ? '#10b981' : '#059669'} 
                      strokeWidth={2}
                      name="Successful Logins"
                    />
                    <Line 
                      type="monotone" 
                      dataKey="failed" 
                      stroke={isDarkMode ? '#ef4444' : '#dc2626'} 
                      strokeWidth={2}
                      name="Failed Attempts"
                    />
                    <Line 
                      type="monotone" 
                      dataKey="sessions" 
                      stroke={isDarkMode ? '#3b82f6' : '#2563eb'} 
                      strokeWidth={2}
                      name="Active Sessions"
                    />
                  </LineChart>
                </ResponsiveContainer>
              </div>

              {/* Recent Authentication Events */}
              <div>
                <h4 className={`font-medium ${themeClasses.primaryText} mb-4`}>Recent Authentication Events</h4>
                <div className="space-y-3">
                  {recentAuthEvents.map((event, index) => (
                    <div key={index} className={`p-3 rounded-lg border ${isDarkMode ? 'border-gray-600 bg-gray-700/20' : 'border-gray-200 bg-white/50'} flex items-center justify-between`}>
                      <div className="flex items-center gap-3">
                        <div className={`p-2 rounded-lg ${
                          event.type === 'success' 
                            ? (isDarkMode ? 'bg-green-900/30 text-green-400' : 'bg-green-100 text-green-600')
                            : event.type === 'failed'
                            ? (isDarkMode ? 'bg-red-900/30 text-red-400' : 'bg-red-100 text-red-600')
                            : event.type === 'logout'
                            ? (isDarkMode ? 'bg-blue-900/30 text-blue-400' : 'bg-blue-100 text-blue-600')
                            : (isDarkMode ? 'bg-orange-900/30 text-orange-400' : 'bg-orange-100 text-orange-600')
                        }`}>
                          {event.type === 'success' && <CheckCircle className="h-4 w-4" />}
                          {event.type === 'failed' && <XCircle className="h-4 w-4" />}
                          {event.type === 'logout' && <LogOut className="h-4 w-4" />}
                          {event.type === 'suspicious' && <AlertTriangle className="h-4 w-4" />}
                        </div>
                        <div>
                          <div className={`text-sm font-medium ${themeClasses.primaryText}`}>
                            {event.user}
                          </div>
                          <div className={`text-xs ${themeClasses.secondaryText}`}>
                            {event.action} • {event.location} • {event.device}
                          </div>
                        </div>
                      </div>
                      <div className={`text-xs ${themeClasses.secondaryText}`}>
                        {event.time}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </CardContent>
        </Card>
      );
    }

    // Revenue Analytics Dashboard
    if (activeSection === 'revenue') {
      return (
