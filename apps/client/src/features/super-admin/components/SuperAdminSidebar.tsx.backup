                <div className="flex items-center justify-between mb-4">
                  <div className={`p-2 rounded-lg ${isDarkMode ? 'bg-green-600/20 text-green-400' : 'bg-green-100 text-green-600'}`}>
                    <DollarSign className="h-4 w-4" />
                  </div>
                  <div className={`text-xs ${isDarkMode ? 'text-green-400' : 'text-green-600'} flex items-center gap-1`}>
                    <TrendingUp className="h-3 w-3" />
                    +23.1%
                  </div>
                </div>
                <div>
                  <div className={`text-2xl font-bold ${themeClasses.primaryText} mb-1`}>
                    £{revenueData?.totalRevenue?.toLocaleString() || '672'}
                  </div>
                  <div className={`text-sm ${themeClasses.secondaryText}`}>Total Revenue</div>
                  <div className={`text-xs ${themeClasses.secondaryText} mt-2`}>
                    This month
                  </div>
                </div>
              </div>

              <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-blue-700/50 bg-gradient-to-br from-blue-900/20 to-blue-800/10 backdrop-blur-sm' : 'border-blue-200 bg-gradient-to-br from-blue-50 to-blue-100/50'}`}>
                <div className="flex items-center justify-between mb-4">
                  <div className={`p-2 rounded-lg ${isDarkMode ? 'bg-blue-600/20 text-blue-400' : 'bg-blue-100 text-blue-600'}`}>
                    <RotateCcw className="h-4 w-4" />
                  </div>
                  <div className={`text-xs ${isDarkMode ? 'text-green-400' : 'text-green-600'} flex items-center gap-1`}>
                    <TrendingUp className="h-3 w-3" />
                    +18.5%
                  </div>
                </div>
                <div>
                  <div className={`text-2xl font-bold ${themeClasses.primaryText} mb-1`}>
                    £{revenueData?.monthlyRecurring || '234'}
                  </div>
                  <div className={`text-sm ${themeClasses.secondaryText}`}>Monthly Recurring</div>
                  <div className={`text-xs ${themeClasses.secondaryText} mt-2`}>
                    MRR Growth
                  </div>
                </div>
              </div>

              <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-purple-700/50 bg-gradient-to-br from-purple-900/20 to-purple-800/10 backdrop-blur-sm' : 'border-purple-200 bg-gradient-to-br from-purple-50 to-purple-100/50'}`}>
                <div className="flex items-center justify-between mb-4">
                  <div className={`p-2 rounded-lg ${isDarkMode ? 'bg-purple-600/20 text-purple-400' : 'bg-purple-100 text-purple-600'}`}>
                    <Target className="h-4 w-4" />
                  </div>
                  <div className={`text-xs ${isDarkMode ? 'text-green-400' : 'text-green-600'} flex items-center gap-1`}>
                    <TrendingUp className="h-3 w-3" />
