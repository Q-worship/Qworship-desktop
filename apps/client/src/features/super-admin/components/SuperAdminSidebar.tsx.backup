                <div className="space-y-4">
                  <div className={`flex items-center justify-between p-4 rounded-lg border transition-colors ${isDarkMode ? 'border-slate-600/40 bg-slate-800/30 hover:bg-slate-800/50' : 'border-gray-200 bg-white/50 hover:bg-gray-50'}`}>
                    <div>
                      <div className={`font-medium ${themeClasses.primaryText}`}>Display Currency</div>
