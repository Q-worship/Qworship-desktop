            {/* Plan Configuration Settings */}
            <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
              <div className={`p-6 rounded-xl border transition-all duration-300 ${isDarkMode ? 'border-slate-600/50 bg-gradient-to-br from-slate-900/40 to-slate-800/30 backdrop-blur-lg shadow-xl' : 'border-gray-200 bg-gradient-to-br from-gray-50/50 to-white/50'}`}>
                <h3 className={`font-semibold ${themeClasses.primaryText} text-lg mb-6 flex items-center gap-2`}>
                  <Globe className={`h-5 w-5 ${isDarkMode ? 'text-blue-400' : 'text-blue-600'}`} />
