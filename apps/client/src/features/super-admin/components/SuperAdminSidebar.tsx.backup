                      <SelectItem value="mrr" className={isDarkMode ? 'text-gray-100 hover:bg-gray-600' : 'text-gray-900 hover:bg-gray-100'}>Monthly Recurring</SelectItem>
                      <SelectItem value="subscriptions" className={isDarkMode ? 'text-gray-100 hover:bg-gray-600' : 'text-gray-900 hover:bg-gray-100'}>Subscriptions</SelectItem>
                      <SelectItem value="upgrades" className={isDarkMode ? 'text-gray-100 hover:bg-gray-600' : 'text-gray-900 hover:bg-gray-100'}>Upgrades</SelectItem>
