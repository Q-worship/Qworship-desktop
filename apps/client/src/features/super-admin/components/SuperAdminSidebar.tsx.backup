            {/* Subscription Breakdown */}
            <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
              <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-gray-700 bg-gradient-to-br from-indigo-900/20 to-purple-900/20 backdrop-blur-sm' : 'border-gray-200 bg-gradient-to-br from-indigo-50/50 to-purple-50/50'}`}>
                <h3 className={`font-semibold ${themeClasses.primaryText} text-lg mb-6`}>Subscription Plans</h3>
                <div className="space-y-4">
                  <div className={`p-4 rounded-lg border ${isDarkMode ? 'border-green-700/30 bg-green-900/10' : 'border-green-200 bg-green-50'}`}>
