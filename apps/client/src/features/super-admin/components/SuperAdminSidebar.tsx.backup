                      })()}
                    </span>
                  </SelectTrigger>
                  <SelectContent className={themeClasses.selectContent}>
                    <SelectItem value="all" className={isDarkMode ? 'text-gray-100 hover:bg-gray-700' : 'text-gray-900 hover:bg-gray-100'}>All Cycles</SelectItem>
                    <SelectItem value="monthly" className={isDarkMode ? 'text-gray-100 hover:bg-gray-700' : 'text-gray-900 hover:bg-gray-100'}>Monthly</SelectItem>
                    <SelectItem value="quarterly" className={isDarkMode ? 'text-gray-100 hover:bg-gray-700' : 'text-gray-900 hover:bg-gray-100'}>Quarterly</SelectItem>
                    <SelectItem value="annual" className={isDarkMode ? 'text-gray-100 hover:bg-gray-700' : 'text-gray-900 hover:bg-gray-100'}>Annual</SelectItem>
                    <SelectItem value="lifetime" className={isDarkMode ? 'text-gray-100 hover:bg-gray-700' : 'text-gray-900 hover:bg-gray-100'}>Lifetime</SelectItem>
                  </SelectContent>
                </Select>
                
                <Button 
                  variant="outline" 
                  onClick={() => {
                    setCustomerFilter('all');
                    setPaymentFilter('all');
                    setCycleFilter('all');
                    setCustomerSearch('');
                  }}
                  className="text-xs"
                >
                  <X className="h-3 w-3 mr-1" />
                  Clear Filters
                </Button>
              </div>
              
              {/* Customer Table */}
              <div className={`border rounded-lg ${isDarkMode ? 'border-gray-600' : 'border-gray-200'} overflow-hidden`}>
                <div className={`grid grid-cols-12 gap-4 p-4 text-xs font-medium ${isDarkMode ? 'bg-gray-800/50 text-gray-300 border-b border-gray-600' : 'bg-gray-50 text-gray-600 border-b border-gray-200'}`}>
                  <div className="col-span-3">Customer</div>
                  <div className="col-span-2">Plan</div>
                  <div className="col-span-1">Amount</div>
                  <div className="col-span-2">Payment Cycle</div>
                  <div className="col-span-2">Next Payment</div>
                  <div className="col-span-1">Status</div>
                  <div className="col-span-1">Actions</div>
                </div>
                
                {filteredCustomers.length === 0 ? (
                  <div className={`p-12 text-center ${isDarkMode ? 'border-gray-600' : 'border-gray-200'}`}>
                    <div className={`w-16 h-16 mx-auto mb-4 rounded-full flex items-center justify-center ${isDarkMode ? 'bg-gray-700/30' : 'bg-gray-100'}`}>
                      <Search className={`h-6 w-6 ${themeClasses.secondaryText}`} />
                    </div>
                    <h3 className={`text-lg font-medium ${themeClasses.primaryText} mb-2`}>No customers found</h3>
                    <p className={`text-sm ${themeClasses.secondaryText} mb-4`}>
                      No customers match your current filter criteria. Try adjusting your search or clearing the filters.
                    </p>
                    <Button 
                      variant="outline" 
                      onClick={() => {
                        setCustomerFilter('all');
                        setPaymentFilter('all');
                        setCycleFilter('all');
                        setCustomerSearch('');
                      }}
                      className="text-xs"
                    >
                      <X className="h-3 w-3 mr-1" />
                      Clear All Filters
                    </Button>
                  </div>
                ) : (
                  filteredCustomers.slice((customerPage - 1) * customerPageSize, customerPage * customerPageSize).map((customer, index) => (
                  <div key={customer.id} className={`grid grid-cols-12 gap-4 p-4 border-b hover:bg-opacity-50 transition-colors ${isDarkMode ? 'border-gray-700 hover:bg-gray-700' : 'border-gray-200 hover:bg-gray-100'}`}>
                    <div className="col-span-3 flex items-center gap-3">
                      <div className={`w-8 h-8 rounded-full flex items-center justify-center text-xs font-semibold ${isDarkMode ? 'bg-blue-600/20 text-blue-400' : 'bg-blue-100 text-blue-600'}`}>
                        {customer.avatar}
                      </div>
                      <div>
                        <div className={`font-medium ${themeClasses.primaryText} text-sm`}>{customer.name}</div>
                        <div className={`text-xs ${themeClasses.secondaryText}`}>{customer.email}</div>
                        <div className={`text-xs ${themeClasses.secondaryText}`}>{customer.organization}</div>
                      </div>
                    </div>
                    <div className="col-span-2 flex items-center">
                      <span className={`px-2 py-1 rounded text-xs font-medium ${
                        customer.plan === 'Enterprise' 
                          ? (isDarkMode ? 'bg-purple-900/30 text-purple-400 border border-purple-700/30' : 'bg-purple-100 text-purple-700 border border-purple-200')
                          : customer.plan === 'Premium'
                          ? (isDarkMode ? 'bg-indigo-900/30 text-indigo-400 border border-indigo-700/30' : 'bg-indigo-100 text-indigo-700 border border-indigo-200')
                          : customer.plan === 'Basic'
                          ? (isDarkMode ? 'bg-blue-900/30 text-blue-400 border border-blue-700/30' : 'bg-blue-100 text-blue-700 border border-blue-200')
                          : (isDarkMode ? 'bg-green-900/30 text-green-400 border border-green-700/30' : 'bg-green-100 text-green-700 border border-green-200')
                      }`}>
                        {customer.plan}
                      </span>
                    </div>
                    <div className={`col-span-1 flex items-center text-sm font-semibold ${themeClasses.primaryText}`}>
                      £{customer.amount}
                    </div>
                    <div className="col-span-2 flex items-center">
                      <div>
                        <div className={`text-sm ${themeClasses.primaryText}`}>{customer.cycle}</div>
                        <div className={`text-xs ${themeClasses.secondaryText}`}>
                          Total: £{customer.totalSpent}
                        </div>
                      </div>
                    </div>
                    <div className="col-span-2 flex items-center">
                      <div>
                        <div className={`text-sm ${themeClasses.primaryText}`}>
                          {new Date(customer.nextPayment).toLocaleDateString()}
                        </div>
                        <div className={`text-xs ${themeClasses.secondaryText}`}>
                          {Math.ceil((new Date(customer.nextPayment).getTime() - Date.now()) / (1000 * 60 * 60 * 24))} days
                        </div>
                      </div>
                    </div>
                    <div className="col-span-1 flex items-center">
                      <span className={`px-2 py-1 rounded text-xs font-medium ${
                        customer.status === 'Active' 
                          ? (isDarkMode ? 'bg-green-900/30 text-green-400 border border-green-700/30' : 'bg-green-100 text-green-700 border border-green-200')
                          : customer.status === 'Trial Ending'
                          ? (isDarkMode ? 'bg-orange-900/30 text-orange-400 border border-orange-700/30' : 'bg-orange-100 text-orange-700 border border-orange-200')
                          : customer.status === 'Payment Due' || customer.status === 'Overdue'
                          ? (isDarkMode ? 'bg-red-900/30 text-red-400 border border-red-700/30' : 'bg-red-100 text-red-700 border border-red-200')
                          : (isDarkMode ? 'bg-gray-700/30 text-gray-400 border border-gray-600/30' : 'bg-gray-100 text-gray-700 border border-gray-200')
                      }`}>
                        {customer.status}
                      </span>
                    </div>
                    <div className="col-span-1 flex items-center">
                      <DropdownMenu>
                        <DropdownMenuTrigger asChild>
                          <Button
                            size="sm"
                            variant="outline"
                            className={`px-2 py-1 h-8 ${themeClasses.selectTrigger}`}
                          >
                            <MoreHorizontal className="h-3 w-3" />
                          </Button>
                        </DropdownMenuTrigger>
                        <DropdownMenuContent 
                          align="end" 
                          className={`${themeClasses.selectContent} min-w-[180px] ${isDarkMode ? 'bg-gray-800/95 border-gray-600 backdrop-blur-md shadow-xl' : 'bg-white/95 border-gray-200 backdrop-blur-md shadow-xl'}`}
                        >
                          <DropdownMenuLabel className={`${themeClasses.primaryText} text-xs font-medium px-3 py-2`}>
                            Customer Actions
                          </DropdownMenuLabel>
                          <DropdownMenuSeparator className={isDarkMode ? 'bg-gray-600' : 'bg-gray-200'} />
                          
                          <DropdownMenuItem 
                            className={`${themeClasses.primaryText} hover:bg-opacity-10 px-3 py-2 text-xs cursor-pointer ${customerActionLoading ? 'opacity-50' : ''}`}
                            onClick={() => handleViewCustomer(customer)}
                            disabled={customerActionLoading}
                          >
                            <Eye className="h-3 w-3 mr-2" />
                            View Details
                          </DropdownMenuItem>
                          
                          <DropdownMenuItem 
                            className={`${themeClasses.primaryText} hover:bg-opacity-10 px-3 py-2 text-xs cursor-pointer ${customerActionLoading ? 'opacity-50' : ''}`}
                            onClick={() => handleViewPaymentHistory(customer)}
                            disabled={customerActionLoading}
                          >
                            <CreditCard className="h-3 w-3 mr-2" />
                            Payment History
                          </DropdownMenuItem>
                          
                          <DropdownMenuItem 
                            className={`${themeClasses.primaryText} hover:bg-opacity-10 px-3 py-2 text-xs cursor-pointer ${customerActionLoading ? 'opacity-50' : ''}`}
                            onClick={() => handleManageSubscription(customer)}
                            disabled={customerActionLoading}
                          >
                            <Settings className="h-3 w-3 mr-2" />
                            Manage Plan
                          </DropdownMenuItem>
                          
                          <DropdownMenuItem 
                            className={`${themeClasses.primaryText} hover:bg-opacity-10 px-3 py-2 text-xs cursor-pointer ${customerActionLoading ? 'opacity-50' : ''}`}
                            onClick={() => handleSendEmail(customer)}
                            disabled={customerActionLoading}
                          >
                            <Mail className="h-3 w-3 mr-2" />
                            Send Invoice
                          </DropdownMenuItem>
                          
                          <DropdownMenuSeparator className={isDarkMode ? 'bg-gray-600' : 'bg-gray-200'} />
                          
                          <DropdownMenuItem 
                            className={`text-red-400 hover:bg-red-900/10 px-3 py-2 text-xs cursor-pointer ${customerActionLoading ? 'opacity-50' : ''}`}
                            onClick={() => handleSuspendAccount(customer)}
                            disabled={customerActionLoading}
                          >
                            <AlertCircle className="h-3 w-3 mr-2" />
                            Suspend Account
                          </DropdownMenuItem>
                        </DropdownMenuContent>
                      </DropdownMenu>
                    </div>
                  </div>
                  ))
                )}
              </div>
              
              {/* Pagination */}
              <div className="flex items-center justify-between mt-6">
                <div className={`text-sm ${themeClasses.secondaryText}`}>
                  Showing {((customerPage - 1) * customerPageSize) + 1} to {Math.min(customerPage * customerPageSize, filteredCustomers.length)} of {filteredCustomers.length} customers
                  {filteredCustomers.length !== customerData.length && (
                    <span className={`ml-2 text-xs ${isDarkMode ? 'text-blue-400' : 'text-blue-600'}`}>
                      (filtered from {customerData.length} total)
                    </span>
                  )}
                </div>
                <div className="flex items-center gap-4">
                  <div className="flex items-center gap-2">
                    <span className={`text-sm ${themeClasses.secondaryText}`}>Rows per page:</span>
                    <Select value={customerPageSize.toString()} onValueChange={(value) => setCustomerPageSize(parseInt(value))}>
                      <SelectTrigger className={`w-20 ${themeClasses.selectTrigger}`}>
                        <span className={isDarkMode ? 'text-gray-100' : 'text-gray-900'}>
                          {customerPageSize}
                        </span>
                      </SelectTrigger>
                      <SelectContent className={themeClasses.selectContent}>
                        <SelectItem value="5" className={isDarkMode ? 'text-gray-100 hover:bg-gray-700' : 'text-gray-900 hover:bg-gray-100'}>5</SelectItem>
                        <SelectItem value="10" className={isDarkMode ? 'text-gray-100 hover:bg-gray-700' : 'text-gray-900 hover:bg-gray-100'}>10</SelectItem>
                        <SelectItem value="25" className={isDarkMode ? 'text-gray-100 hover:bg-gray-700' : 'text-gray-900 hover:bg-gray-100'}>25</SelectItem>
                        <SelectItem value="50" className={isDarkMode ? 'text-gray-100 hover:bg-gray-700' : 'text-gray-900 hover:bg-gray-100'}>50</SelectItem>
                      </SelectContent>
                    </Select>
                  </div>
                  <div className="flex items-center gap-2">
                    <Button
                      size="sm"
                      variant="outline"
                      onClick={() => setCustomerPage(Math.max(1, customerPage - 1))}
                      disabled={customerPage === 1}
                      className={`px-3 py-1 ${themeClasses.selectTrigger}`}
                    >
                      <ChevronLeft className="h-3 w-3" />
                    </Button>
                    <span className={`text-sm ${themeClasses.primaryText} px-3`}>
                      Page {customerPage} of {Math.ceil(filteredCustomers.length / customerPageSize) || 1}
                    </span>
                    <Button
                      size="sm"
                      variant="outline"
                      onClick={() => setCustomerPage(Math.min(Math.ceil(filteredCustomers.length / customerPageSize) || 1, customerPage + 1))}
                      disabled={customerPage >= Math.ceil(filteredCustomers.length / customerPageSize) || filteredCustomers.length === 0}
                      className={`px-3 py-1 ${themeClasses.selectTrigger}`}
                    >
                      <ChevronRight className="h-3 w-3" />
                    </Button>
                  </div>
                </div>
              </div>
            </div>
          </CardContent>
        </Card>
      );
    }

    // System Health Dashboard
    if (activeSection === 'system') {
      return (
        <Card className={`${themeClasses.analyticsCard} backdrop-blur-sm`}>
          <CardHeader className={`pb-6 border-b ${themeClasses.border}`}>
            <div className="flex items-center justify-between">
              <div className="flex items-center gap-3">
                <div className={`p-2 rounded-lg ${isDarkMode ? 'bg-gradient-to-br from-emerald-900/50 to-green-900/50 text-emerald-400' : 'bg-gradient-to-br from-emerald-100 to-green-100 text-emerald-600'}`}>
                  <Activity className="h-6 w-6" />
                </div>
                <div>
                  <CardTitle className={`${themeClasses.primaryText} text-2xl font-bold`}>
                    System Health
                  </CardTitle>
                  <CardDescription className={`${themeClasses.secondaryText} text-base`}>
                    Platform monitoring, performance metrics, and infrastructure status
                  </CardDescription>
                </div>
              </div>
              <div className="flex items-center gap-3">
                <Badge className={`${isDarkMode ? 'bg-green-900/30 text-green-400 border-green-700' : 'bg-green-100 text-green-800 border-green-200'}`}>
                  <div className="w-2 h-2 rounded-full bg-green-500 mr-2 animate-pulse"></div>
                  All Systems Operational
                </Badge>
                <Button size="sm" variant="outline" onClick={exportData}>
                  <Download className="h-3 w-3 mr-1" />
                  Export
                </Button>
              </div>
            </div>
          </CardHeader>
          <CardContent className="space-y-8 pt-6">
            {/* System Status Overview */}
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
              <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-green-700/50 bg-gradient-to-br from-green-900/20 to-green-800/10 backdrop-blur-sm' : 'border-green-200 bg-gradient-to-br from-green-50 to-green-100/50'}`}>
                <div className="flex items-center justify-between mb-4">
                  <div className={`p-2 rounded-lg ${isDarkMode ? 'bg-green-600/20 text-green-400' : 'bg-green-100 text-green-600'}`}>
                    <Gauge className="h-4 w-4" />
                  </div>
                  <div className={`text-xs ${isDarkMode ? 'text-green-400' : 'text-green-600'} flex items-center gap-1`}>
                    <CheckCircle className="h-3 w-3" />
                    Excellent
                  </div>
                </div>
                <div>
                  <div className={`text-2xl font-bold ${themeClasses.primaryText} mb-1`}>
                    99.8%
                  </div>
                  <div className={`text-sm ${themeClasses.secondaryText}`}>Uptime</div>
                  <div className={`text-xs ${themeClasses.secondaryText} mt-2`}>
                    30-day average
                  </div>
                </div>
              </div>

              <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-blue-700/50 bg-gradient-to-br from-blue-900/20 to-blue-800/10 backdrop-blur-sm' : 'border-blue-200 bg-gradient-to-br from-blue-50 to-blue-100/50'}`}>
                <div className="flex items-center justify-between mb-4">
                  <div className={`p-2 rounded-lg ${isDarkMode ? 'bg-blue-600/20 text-blue-400' : 'bg-blue-100 text-blue-600'}`}>
                    <Clock className="h-4 w-4" />
                  </div>
                  <div className={`text-xs ${isDarkMode ? 'text-green-400' : 'text-green-600'} flex items-center gap-1`}>
                    <CheckCircle className="h-3 w-3" />
                    Fast
                  </div>
                </div>
                <div>
                  <div className={`text-2xl font-bold ${themeClasses.primaryText} mb-1`}>
                    89ms
                  </div>
                  <div className={`text-sm ${themeClasses.secondaryText}`}>Response Time</div>
                  <div className={`text-xs ${themeClasses.secondaryText} mt-2`}>
                    Average API latency
                  </div>
                </div>
              </div>

              <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-purple-700/50 bg-gradient-to-br from-purple-900/20 to-purple-800/10 backdrop-blur-sm' : 'border-purple-200 bg-gradient-to-br from-purple-50 to-purple-100/50'}`}>
                <div className="flex items-center justify-between mb-4">
                  <div className={`p-2 rounded-lg ${isDarkMode ? 'bg-purple-600/20 text-purple-400' : 'bg-purple-100 text-purple-600'}`}>
                    <Server className="h-4 w-4" />
                  </div>
                  <div className={`text-xs ${isDarkMode ? 'text-yellow-400' : 'text-yellow-600'} flex items-center gap-1`}>
                    <AlertTriangle className="h-3 w-3" />
                    Moderate
                  </div>
                </div>
                <div>
                  <div className={`text-2xl font-bold ${themeClasses.primaryText} mb-1`}>
                    67%
                  </div>
                  <div className={`text-sm ${themeClasses.secondaryText}`}>CPU Usage</div>
                  <div className={`text-xs ${themeClasses.secondaryText} mt-2`}>
                    Server load average
                  </div>
                </div>
              </div>

              <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-orange-700/50 bg-gradient-to-br from-orange-900/20 to-orange-800/10 backdrop-blur-sm' : 'border-orange-200 bg-gradient-to-br from-orange-50 to-orange-100/50'}`}>
                <div className="flex items-center justify-between mb-4">
                  <div className={`p-2 rounded-lg ${isDarkMode ? 'bg-orange-600/20 text-orange-400' : 'bg-orange-100 text-orange-600'}`}>
                    <Database className="h-4 w-4" />
                  </div>
                  <div className={`text-xs ${isDarkMode ? 'text-green-400' : 'text-green-600'} flex items-center gap-1`}>
                    <CheckCircle className="h-3 w-3" />
                    Healthy
                  </div>
                </div>
                <div>
                  <div className={`text-2xl font-bold ${themeClasses.primaryText} mb-1`}>
                    42ms
                  </div>
                  <div className={`text-sm ${themeClasses.secondaryText}`}>DB Query Time</div>
                  <div className={`text-xs ${themeClasses.secondaryText} mt-2`}>
                    Average query latency
                  </div>
                </div>
              </div>
            </div>

            {/* System Performance Chart */}
            <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-gray-700 bg-gradient-to-br from-gray-900/30 to-gray-800/20 backdrop-blur-sm' : 'border-gray-200 bg-gradient-to-br from-gray-50/50 to-white/50'}`}>
              <div className="flex items-center justify-between mb-6">
                <h3 className={`font-semibold ${themeClasses.primaryText} text-lg`}>Performance Metrics</h3>
                <div className="flex items-center gap-2">
                  <Select value={chartMetric} onValueChange={setChartMetric}>
                    <SelectTrigger className={`w-40 ${themeClasses.selectTrigger}`}>
                      <SelectValue />
                    </SelectTrigger>
                    <SelectContent className={themeClasses.selectContent}>
                      <SelectItem value="uptime">Uptime %</SelectItem>
                      <SelectItem value="response">Response Time</SelectItem>
                      <SelectItem value="cpu">CPU Usage</SelectItem>
                      <SelectItem value="memory">Memory Usage</SelectItem>
                    </SelectContent>
                  </Select>
                </div>
              </div>
              <div className="h-64">
                <ResponsiveContainer width="100%" height="100%">
                  <LineChart data={systemPerformanceData}>
                    <CartesianGrid strokeDasharray="3 3" stroke={isDarkMode ? '#374151' : '#e5e7eb'} />
                    <XAxis 
                      dataKey="time" 
                      stroke={isDarkMode ? '#9ca3af' : '#6b7280'}
                      fontSize={12}
                    />
                    <YAxis 
                      stroke={isDarkMode ? '#9ca3af' : '#6b7280'}
                      fontSize={12}
                    />
                    <Tooltip 
                      contentStyle={{
                        backgroundColor: isDarkMode ? '#1f2937' : '#ffffff',
                        border: `1px solid ${isDarkMode ? '#374151' : '#e5e7eb'}`,
                        borderRadius: '8px',
                        color: isDarkMode ? '#f9fafb' : '#111827'
                      }}
                    />
                    <Line 
                      type="monotone" 
                      dataKey="uptime" 
                      stroke="#10b981" 
                      strokeWidth={2}
                      dot={{ fill: '#10b981', strokeWidth: 2, r: 4 }}
                    />
                    <Line 
                      type="monotone" 
                      dataKey="response" 
                      stroke="#3b82f6" 
                      strokeWidth={2}
                      dot={{ fill: '#3b82f6', strokeWidth: 2, r: 4 }}
                    />
                  </LineChart>
                </ResponsiveContainer>
              </div>
            </div>

            {/* System Components Status */}
            <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
              <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-gray-700 bg-gradient-to-br from-indigo-900/20 to-purple-900/20 backdrop-blur-sm' : 'border-gray-200 bg-gradient-to-br from-indigo-50/50 to-purple-50/50'}`}>
                <h3 className={`font-semibold ${themeClasses.primaryText} text-lg mb-6`}>Service Status</h3>
                <div className="space-y-4">
                  <div className={`p-4 rounded-lg border ${isDarkMode ? 'border-green-700/30 bg-green-900/10' : 'border-green-200 bg-green-50'}`}>
                    <div className="flex items-center justify-between">
                      <div className="flex items-center gap-3">
                        <div className={`p-2 rounded-full ${isDarkMode ? 'bg-green-600/20 text-green-400' : 'bg-green-100 text-green-600'}`}>
                          <Server className="h-3 w-3" />
                        </div>
                        <div>
                          <div className={`text-sm font-medium ${themeClasses.primaryText}`}>Web Server</div>
                          <div className={`text-xs ${themeClasses.secondaryText}`}>Express.js API</div>
                        </div>
                      </div>
                      <Badge className={`${isDarkMode ? 'bg-green-900/30 text-green-400 border-green-700' : 'bg-green-100 text-green-800 border-green-200'} text-xs`}>
                        Operational
                      </Badge>
                    </div>
                  </div>

                  <div className={`p-4 rounded-lg border ${isDarkMode ? 'border-green-700/30 bg-green-900/10' : 'border-green-200 bg-green-50'}`}>
                    <div className="flex items-center justify-between">
                      <div className="flex items-center gap-3">
                        <div className={`p-2 rounded-full ${isDarkMode ? 'bg-green-600/20 text-green-400' : 'bg-green-100 text-green-600'}`}>
                          <Database className="h-3 w-3" />
                        </div>
                        <div>
                          <div className={`text-sm font-medium ${themeClasses.primaryText}`}>Database</div>
                          <div className={`text-xs ${themeClasses.secondaryText}`}>PostgreSQL</div>
                        </div>
                      </div>
                      <Badge className={`${isDarkMode ? 'bg-green-900/30 text-green-400 border-green-700' : 'bg-green-100 text-green-800 border-green-200'} text-xs`}>
                        Operational
                      </Badge>
                    </div>
                  </div>

                  <div className={`p-4 rounded-lg border ${isDarkMode ? 'border-yellow-700/30 bg-yellow-900/10' : 'border-yellow-200 bg-yellow-50'}`}>
                    <div className="flex items-center justify-between">
                      <div className="flex items-center gap-3">
                        <div className={`p-2 rounded-full ${isDarkMode ? 'bg-yellow-600/20 text-yellow-400' : 'bg-yellow-100 text-yellow-600'}`}>
                          <Mail className="h-3 w-3" />
                        </div>
                        <div>
                          <div className={`text-sm font-medium ${themeClasses.primaryText}`}>Email Service</div>
                          <div className={`text-xs ${themeClasses.secondaryText}`}>SMTP Gateway</div>
                        </div>
                      </div>
                      <Badge className={`${isDarkMode ? 'bg-yellow-900/30 text-yellow-400 border-yellow-700' : 'bg-yellow-100 text-yellow-800 border-yellow-200'} text-xs`}>
                        Degraded
                      </Badge>
                    </div>
                  </div>

                  <div className={`p-4 rounded-lg border ${isDarkMode ? 'border-green-700/30 bg-green-900/10' : 'border-green-200 bg-green-50'}`}>
                    <div className="flex items-center justify-between">
                      <div className="flex items-center gap-3">
                        <div className={`p-2 rounded-full ${isDarkMode ? 'bg-green-600/20 text-green-400' : 'bg-green-100 text-green-600'}`}>
                          <Mic className="h-3 w-3" />
                        </div>
                        <div>
                          <div className={`text-sm font-medium ${themeClasses.primaryText}`}>Bible Widget</div>
                          <div className={`text-xs ${themeClasses.secondaryText}`}>AI Speech Recognition</div>
                        </div>
                      </div>
                      <Badge className={`${isDarkMode ? 'bg-green-900/30 text-green-400 border-green-700' : 'bg-green-100 text-green-800 border-green-200'} text-xs`}>
                        Operational
                      </Badge>
                    </div>
