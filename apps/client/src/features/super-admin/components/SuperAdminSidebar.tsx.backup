                <div className={`${isDarkMode ? 'bg-gradient-to-r from-gray-800/70 to-gray-700/50 backdrop-blur-sm' : 'bg-gray-50'} px-6 py-4 border-b ${isDarkMode ? 'border-gray-600/30' : 'border-gray-200'}`}>
                  <div className="grid grid-cols-[2fr_1.5fr_1.2fr_1fr_1fr_1fr_1fr_0.8fr] gap-4 text-sm font-medium">
                    <div className={`${themeClasses.primaryText}`}>User</div>
                    <div className={`${themeClasses.primaryText}`}>Organization</div>
                    <div className={`${themeClasses.primaryText}`}>Current Step</div>
                    <div className={`${themeClasses.primaryText}`}>Progress</div>
                    <div className={`${themeClasses.primaryText}`}>Status</div>
                    <div className={`${themeClasses.primaryText}`}>Started</div>
                    <div className={`${themeClasses.primaryText}`}>Time Spent</div>
                    <div className={`${themeClasses.primaryText}`}>Actions</div>
                  </div>
                </div>
                <div className={`${isDarkMode ? 'bg-gradient-to-b from-gray-900/40 to-gray-800/20' : 'bg-white'}`}>
                  {/* Sample Onboarding Records */}
                  {[
                    {
                      id: 1,
                      name: "Pastor John Smith",
                      email: "john.smith@gracechurch.org",
                      organization: "Grace Community Church",
                      currentStep: "plan_selection",
                      progress: 75,
                      status: "in_progress",
                      started: "2024-07-28",
                      timeSpent: "12m 34s",
                      avatar: "JS"
                    },
                    {
                      id: 2,
                      name: "Sarah Johnson",
                      email: "sarah@harvesthope.com",
                      organization: "Harvest Hope Ministry",
                      currentStep: "account_activation",
                      progress: 90,
                      status: "in_progress",
                      started: "2024-07-27",
                      timeSpent: "8m 21s",
                      avatar: "SJ"
                    },
                    {
                      id: 3,
                      name: "Michael Rodriguez",
                      email: "m.rodriguez@faithpoint.org",
                      organization: "Faith Point Church",
                      currentStep: "organization_setup",
                      progress: 60,
                      status: "stalled",
                      started: "2024-07-26",
                      timeSpent: "25m 17s",
                      avatar: "MR"
                    },
                    {
                      id: 4,
                      name: "Jennifer Lee",
                      email: "jennifer.lee@newlife.church",
                      organization: "New Life Fellowship",
                      currentStep: "account_activation",
                      progress: 100,
                      status: "completed",
                      started: "2024-07-25",
                      timeSpent: "15m 43s",
                      avatar: "JL"
                    },
                    {
                      id: 5,
                      name: "David Thompson",
                      email: "david@crossroads.net",
                      organization: "Crossroads Baptist",
                      currentStep: "email_verification",
                      progress: 25,
                      status: "abandoned",
                      started: "2024-07-24",
                      timeSpent: "3m 12s",
                      avatar: "DT"
                    }
                  ].map((user, index) => (
                    <div key={user.id} className={`px-6 py-4 border-b ${isDarkMode ? 'border-gray-600/20' : 'border-gray-100'} hover:${isDarkMode ? 'bg-gradient-to-r from-gray-800/50 to-gray-700/30 backdrop-blur-sm shadow-lg' : 'bg-gray-50'} transition-all duration-300 group`}>
                      <div className="grid grid-cols-[2fr_1.5fr_1.2fr_1fr_1fr_1fr_1fr_0.8fr] gap-4 items-center text-sm">
                        {/* User */}
                        <div className="flex items-center gap-3 min-w-0">
                          <div className={`w-8 h-8 rounded-full bg-gradient-to-r from-blue-500 to-purple-600 flex items-center justify-center text-white text-xs font-semibold ${isDarkMode ? 'shadow-lg ring-2 ring-gray-600/20 group-hover:ring-blue-400/30 group-hover:shadow-blue-500/20' : 'shadow-md'} transition-all duration-300 flex-shrink-0`}>
                            {user.avatar}
                          </div>
                          <div className="min-w-0 flex-1">
                            <div className={`font-medium ${themeClasses.primaryText} truncate`}>{user.name}</div>
                            <div className={`text-xs ${themeClasses.secondaryText} truncate`}>{user.email}</div>
                          </div>
                        </div>

                        {/* Organization */}
                        <div className={`${themeClasses.primaryText} text-sm truncate`}>{user.organization}</div>

                        {/* Current Step */}
                        <div>
                          <div className={`inline-flex items-center px-2 py-1 rounded-full text-xs font-medium ${
                            user.currentStep === 'registration' ? (isDarkMode ? 'bg-blue-900/30 text-blue-400' : 'bg-blue-100 text-blue-700') :
                            user.currentStep === 'email_verification' ? (isDarkMode ? 'bg-indigo-900/30 text-indigo-400' : 'bg-indigo-100 text-indigo-700') :
                            user.currentStep === 'organization_setup' ? (isDarkMode ? 'bg-purple-900/30 text-purple-400' : 'bg-purple-100 text-purple-700') :
                            user.currentStep === 'plan_selection' ? (isDarkMode ? 'bg-pink-900/30 text-pink-400' : 'bg-pink-100 text-pink-700') :
                            (isDarkMode ? 'bg-green-900/30 text-green-400' : 'bg-green-100 text-green-700')
                          }`}>
                            {user.currentStep === 'registration' && <UserPlus className="h-3 w-3 mr-1" />}
                            {user.currentStep === 'email_verification' && <Mail className="h-3 w-3 mr-1" />}
                            {user.currentStep === 'organization_setup' && <Building2 className="h-3 w-3 mr-1" />}
                            {user.currentStep === 'plan_selection' && <CreditCard className="h-3 w-3 mr-1" />}
                            {user.currentStep === 'account_activation' && <CheckCircle className="h-3 w-3 mr-1" />}
                            {user.currentStep.replace('_', ' ').split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ')}
                          </div>
                        </div>

                        {/* Progress */}
                        <div className="flex items-center gap-2">
                          <div className={`flex-1 h-2 rounded-full ${isDarkMode ? 'bg-gray-700/50 ring-1 ring-gray-600/20' : 'bg-gray-200'} overflow-hidden ${isDarkMode ? 'shadow-inner' : ''}`}>
                            <div 
                              className={`h-full rounded-full transition-all duration-500 ease-out group-hover:shadow-lg ${
                                user.progress === 100 ? (isDarkMode ? 'bg-gradient-to-r from-green-400 to-green-500 shadow-green-500/20' : 'bg-gradient-to-r from-green-500 to-green-600') :
                                user.progress >= 75 ? (isDarkMode ? 'bg-gradient-to-r from-blue-400 to-blue-500 shadow-blue-500/20' : 'bg-gradient-to-r from-blue-500 to-blue-600') :
                                user.progress >= 50 ? (isDarkMode ? 'bg-gradient-to-r from-yellow-400 to-yellow-500 shadow-yellow-500/20' : 'bg-gradient-to-r from-yellow-500 to-yellow-600') :
                                (isDarkMode ? 'bg-gradient-to-r from-red-400 to-red-500 shadow-red-500/20' : 'bg-gradient-to-r from-red-500 to-red-600')
                              }`}
                              style={{ width: `${user.progress}%` }}
                            ></div>
                          </div>
                          <span className={`text-xs font-semibold ${themeClasses.primaryText} min-w-[35px] group-hover:text-blue-400 transition-colors duration-300`}>{user.progress}%</span>
                        </div>

                        {/* Status */}
                        <div>
                          <div className={`inline-flex items-center px-3 py-1 rounded-full text-xs font-semibold transition-all duration-300 ${
                            user.status === 'completed' ? (isDarkMode ? 'bg-green-900/50 text-green-300 ring-1 ring-green-400/20 shadow-green-500/10 group-hover:shadow-green-500/20' : 'bg-green-100 text-green-700') :
                            user.status === 'in_progress' ? (isDarkMode ? 'bg-blue-900/50 text-blue-300 ring-1 ring-blue-400/20 shadow-blue-500/10 group-hover:shadow-blue-500/20' : 'bg-blue-100 text-blue-700') :
                            user.status === 'stalled' ? (isDarkMode ? 'bg-yellow-900/50 text-yellow-300 ring-1 ring-yellow-400/20 shadow-yellow-500/10 group-hover:shadow-yellow-500/20' : 'bg-yellow-100 text-yellow-700') :
                            (isDarkMode ? 'bg-red-900/50 text-red-300 ring-1 ring-red-400/20 shadow-red-500/10 group-hover:shadow-red-500/20' : 'bg-red-100 text-red-700')
                          }`}>
                            {user.status === 'completed' && <CheckCircle className="h-3 w-3 mr-1" />}
                            {user.status === 'in_progress' && <Clock className="h-3 w-3 mr-1" />}
                            {user.status === 'stalled' && <AlertTriangle className="h-3 w-3 mr-1" />}
                            {user.status === 'abandoned' && <XCircle className="h-3 w-3 mr-1" />}
                            {user.status.charAt(0).toUpperCase() + user.status.slice(1).replace('_', ' ')}
                          </div>
                        </div>

                        {/* Started */}
                        <div className={`text-sm ${themeClasses.secondaryText}`}>{user.started}</div>

                        {/* Time Spent */}
                        <div className={`text-sm ${themeClasses.primaryText} font-medium`}>{user.timeSpent}</div>

                        {/* Actions */}
                        <div className="flex items-center gap-1">
                          <DropdownMenu>
                            <DropdownMenuTrigger asChild>
                              <Button size="sm" variant="ghost" className={`h-8 w-8 p-0 ${isDarkMode ? 'hover:bg-gray-700/50 hover:shadow-lg hover:ring-1 hover:ring-gray-600/20 text-gray-400 hover:text-gray-200' : ''} transition-all duration-300 group-hover:scale-110`}>
                                <MoreHorizontal className="h-4 w-4" />
                              </Button>
                            </DropdownMenuTrigger>
                            <DropdownMenuContent align="end" className={themeClasses.selectContent}>
                              <DropdownMenuItem 
                                className="text-xs cursor-pointer hover:bg-blue-500/10"
                                onClick={() => {
                                  setSelectedUserId(user.id);
                                  setActiveSection('user-profile');
                                }}
                              >
                                <Eye className="h-3 w-3 mr-2" />
                                View Details
                              </DropdownMenuItem>
                              <DropdownMenuItem 
                                className="text-xs cursor-pointer hover:bg-green-500/10"
                                onClick={() => {
                                  toast({
                                    title: "Reminder Sent",
                                    description: `Onboarding reminder sent to ${user.name}`,
                                  });
                                }}
                              >
                                <Mail className="h-3 w-3 mr-2" />
                                Send Reminder
                              </DropdownMenuItem>
                              <DropdownMenuItem 
                                className="text-xs cursor-pointer hover:bg-yellow-500/10"
                                onClick={() => {
                                  toast({
                                    title: "Edit Progress",
                                    description: `Opening progress editor for ${user.name}`,
                                  });
                                }}
                              >
                                <Edit className="h-3 w-3 mr-2" />
                                Edit Progress
                              </DropdownMenuItem>
                              <DropdownMenuSeparator />
                              <DropdownMenuItem 
                                className="text-xs text-red-600 cursor-pointer hover:bg-red-500/10"
                                onClick={() => {
                                  if (confirm(`Are you sure you want to reset onboarding progress for ${user.name}?`)) {
                                    toast({
                                      title: "Progress Reset",
                                      description: `Onboarding progress reset for ${user.name}`,
                                    });
                                  }
                                }}
                              >
                                <Trash2 className="h-3 w-3 mr-2" />
                                Reset Progress
                              </DropdownMenuItem>
                            </DropdownMenuContent>
                          </DropdownMenu>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>

              {/* Pagination */}
              <div className={`flex items-center justify-between mt-6 pt-4 border-t ${isDarkMode ? 'border-gray-600/20' : 'border-gray-200'}`}>
                <div className={`text-sm ${themeClasses.secondaryText} font-medium`}>
                  Showing 1-5 of 247 onboarding activities
                </div>
                <div className="flex items-center gap-2">
                  <Button size="sm" variant="outline" disabled className={`text-xs ${isDarkMode ? 'border-gray-600/30 text-gray-500 bg-gray-800/20' : ''}`}>
                    <ChevronLeft className="h-3 w-3 mr-1" />
                    Previous
                  </Button>
                  <div className="flex items-center gap-1">
                    {[1, 2, 3, '...', 50].map((page, index) => (
                      <Button
                        key={index}
                        size="sm"
                        variant={page === 1 ? "default" : "outline"}
                        className={`w-8 h-8 p-0 text-xs transition-all duration-300 ${
                          page === 1 
                            ? (isDarkMode ? 'bg-blue-600 hover:bg-blue-700 shadow-lg shadow-blue-500/20 ring-1 ring-blue-400/20' : 'bg-blue-600 hover:bg-blue-700') 
                            : (isDarkMode ? 'border-gray-600/30 hover:bg-gray-700/50 hover:border-gray-500/50 hover:shadow-lg' : '')
                        }`}
                        disabled={page === '...'}
                      >
                        {page}
                      </Button>
                    ))}
                  </div>
                  <Button size="sm" variant="outline" className={`text-xs ${isDarkMode ? 'border-gray-600/30 hover:bg-gray-700/50 hover:border-gray-500/50 hover:shadow-lg' : ''} transition-all duration-300`}>
                    Next
                    <ChevronRight className="h-3 w-3 ml-1" />
                  </Button>
                </div>
              </div>
            </div>
          </CardContent>
        </Card>
      );
    }



    // Authentication Tracking Dashboard
    if (activeSection === 'authentication') {
      return (
        <Card className={`${themeClasses.analyticsCard} backdrop-blur-sm`}>
          <CardHeader className={`pb-6 border-b ${themeClasses.border}`}>
            <div className="flex items-center justify-between">
              <div className="flex items-center gap-3">
                <div className={`p-2 rounded-lg ${isDarkMode ? 'bg-gradient-to-br from-red-900/50 to-pink-900/50 text-red-400' : 'bg-gradient-to-br from-red-100 to-pink-100 text-red-600'}`}>
                  <Shield className="h-6 w-6" />
                </div>
                <div>
                  <CardTitle className={`${themeClasses.primaryText} text-2xl font-bold`}>
                    Authentication Tracking
                  </CardTitle>
