        const response = await apiRequest('POST', `/api/admin/create-admin?adminKey=${adminKey}`, {
          ...adminData,
          username: adminData.email
        });
        return response;
      },
      onSuccess: () => {
        setShowCreateForm(false);
        setNewAdmin({ email: '', firstName: '', lastName: '', adminType: 'administrator', password: '' });
        refetchAdmins();
        toast({
          title: "Success",
          description: "Admin account created successfully",
