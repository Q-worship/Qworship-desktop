                <div className="space-y-2 mb-6">
                  <div className={`text-sm ${themeClasses.primaryText} flex items-center gap-2`}>
                    <CheckCircle className={`h-4 w-4 ${isDarkMode ? 'text-green-400' : 'text-green-500'}`} />
