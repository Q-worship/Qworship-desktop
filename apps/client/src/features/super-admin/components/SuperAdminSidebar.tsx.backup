            </div>

            {/* Customer Subscription Management Table */}
            <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-gray-700 bg-gradient-to-br from-gray-900/30 to-gray-800/20 backdrop-blur-sm' : 'border-gray-200 bg-gradient-to-br from-gray-50/50 to-white/50'} mt-8`}>
              <div className="flex items-center justify-between mb-6">
