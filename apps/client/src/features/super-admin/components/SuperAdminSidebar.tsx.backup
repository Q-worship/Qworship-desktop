                    lastActive: '1 day ago',
                    avatar: 'MC'
                  },
                  {
                    id: 3,
                    name: 'Emily Rodriguez',
                    email: 'emily@cityheightsbaptist.org',
                    organization: 'City Heights Baptist',
                    plan: 'Free Trial',
                    status: 'Active',
                    lastActive: '3 hours ago',
                    avatar: 'ER'
                  },
                  {
                    id: 4,
                    name: 'David Thompson',
                    email: 'david@riverside.church',
                    organization: 'Riverside Methodist',
                    plan: 'Basic',
                    status: 'Payment Due',
                    lastActive: '5 days ago',
                    avatar: 'DT'
                  },
                  {
                    id: 5,
                    name: 'Lisa Park',
                    email: 'lisa@hopechurch.international',
                    organization: 'Hope Church International',
                    plan: 'Premium',
                    status: 'Active',
                    lastActive: '1 hour ago',
                    avatar: 'LP'
                  },
                  {
                    id: 6,
                    name: 'James Wilson',
                    email: 'james@trinityanglican.org',
                    organization: 'Trinity Anglican Church',
                    plan: 'Basic',
                    status: 'Active',
                    lastActive: '4 hours ago',
                    avatar: 'JW'
                  },
                  {
                    id: 7,
                    name: 'Maria Santos',
                    email: 'maria@stmarks.church',
                    organization: 'St. Mark\'s Catholic',
                    plan: 'Free Trial',
                    status: 'Trial Ending',
                    lastActive: '2 days ago',
                    avatar: 'MS'
                  },
                  {
                    id: 8,
                    name: 'Robert Lee',
                    email: 'robert@faithcommunity.org',
                    organization: 'Faith Community Church',
                    plan: 'Premium',
                    status: 'Suspended',
                    lastActive: '1 week ago',
                    avatar: 'RL'
                  },
                  {
                    id: 9,
                    name: 'Jennifer Brown',
                    email: 'jennifer@crossroads.church',
                    organization: 'Crossroads Fellowship',
                    plan: 'Basic',
                    status: 'Active',
                    lastActive: '6 hours ago',
                    avatar: 'JB'
                  },
                  {
                    id: 10,
                    name: 'Thomas Anderson',
                    email: 'thomas@lighthouse.ministry',
                    organization: 'Lighthouse Ministry',
                    plan: 'Free Trial',
                    status: 'Active',
                    lastActive: '30 minutes ago',
                    avatar: 'TA'
                  }
                ].map((user, index) => (
                  <div key={user.id} className={`grid grid-cols-12 gap-4 p-4 border-b hover:bg-opacity-50 transition-colors ${isDarkMode ? 'border-gray-700 hover:bg-gray-700' : 'border-gray-200 hover:bg-gray-100'}`}>
                    <div className="col-span-3 flex items-center gap-3">
                      <div className={`w-8 h-8 rounded-full flex items-center justify-center text-xs font-semibold ${isDarkMode ? 'bg-blue-600/20 text-blue-400' : 'bg-blue-100 text-blue-600'}`}>
                        {user.avatar}
                      </div>
                      <div>
                        <div className={`font-medium ${themeClasses.primaryText} text-sm`}>{user.name}</div>
                        <div className={`text-xs ${themeClasses.secondaryText}`}>{user.email}</div>
                      </div>
                    </div>
                    <div className={`col-span-2 flex items-center text-sm ${themeClasses.primaryText}`}>
                      {user.organization}
                    </div>
                    <div className="col-span-2 flex items-center">
                      <span className={`px-2 py-1 rounded text-xs font-medium ${
                        user.plan === 'Premium' 
                          ? (isDarkMode ? 'bg-purple-900/30 text-purple-400 border border-purple-700/30' : 'bg-purple-100 text-purple-700 border border-purple-200')
                          : user.plan === 'Basic'
                          ? (isDarkMode ? 'bg-blue-900/30 text-blue-400 border border-blue-700/30' : 'bg-blue-100 text-blue-700 border border-blue-200')
                          : (isDarkMode ? 'bg-green-900/30 text-green-400 border border-green-700/30' : 'bg-green-100 text-green-700 border border-green-200')
                      }`}>
                        {user.plan}
                      </span>
                    </div>
                    <div className="col-span-2 flex items-center">
                      <span className={`px-2 py-1 rounded text-xs font-medium ${
                        user.status === 'Active' 
                          ? (isDarkMode ? 'bg-green-900/30 text-green-400 border border-green-700/30' : 'bg-green-100 text-green-700 border border-green-200')
                          : user.status === 'Trial' || user.status === 'Trial Ending'
                          ? (isDarkMode ? 'bg-orange-900/30 text-orange-400 border border-orange-700/30' : 'bg-orange-100 text-orange-700 border border-orange-200')
                          : user.status === 'Payment Due'
                          ? (isDarkMode ? 'bg-red-900/30 text-red-400 border border-red-700/30' : 'bg-red-100 text-red-700 border border-red-200')
                          : (isDarkMode ? 'bg-gray-700/30 text-gray-400 border border-gray-600/30' : 'bg-gray-100 text-gray-700 border border-gray-200')
                      }`}>
                        {user.status}
                      </span>
                    </div>
                    <div className={`col-span-2 flex items-center text-sm ${themeClasses.secondaryText}`}>
                      {user.lastActive}
                    </div>
                    <div className="col-span-1 flex items-center">
                      <DropdownMenu>
                        <DropdownMenuTrigger asChild>
                          <Button
                            size="sm"
                            variant="outline"
                            className={`px-2 py-1 h-8 ${themeClasses.selectTrigger} ${userActionLoading && selectedUserId === user.id ? 'opacity-50' : ''}`}
                            disabled={userActionLoading && selectedUserId === user.id}
                          >
                            <MoreHorizontal className="h-3 w-3" />
                          </Button>
                        </DropdownMenuTrigger>
                        <DropdownMenuContent 
                          align="end" 
                          className={`${themeClasses.selectContent} min-w-[200px] ${isDarkMode ? 'bg-gray-800/95 border-gray-600 backdrop-blur-md shadow-xl' : 'bg-white/95 border-gray-200 backdrop-blur-md shadow-xl'}`}
                        >
                          <DropdownMenuLabel className={`${themeClasses.primaryText} text-xs font-medium px-3 py-2`}>
                            User Actions
                          </DropdownMenuLabel>
                          <DropdownMenuSeparator className={isDarkMode ? 'bg-gray-600' : 'bg-gray-200'} />
                          
                          <DropdownMenuItem 
                            onClick={() => handleUserAction(user.id, 'view', user)}
                            className={`${themeClasses.dropdownItem} cursor-pointer hover:bg-opacity-80 transition-colors duration-200 px-3 py-2`}
                          >
                            <Eye className={`h-4 w-4 mr-2 ${isDarkMode ? 'text-blue-400' : 'text-blue-600'}`} />
                            <span className="text-sm">View Profile</span>
                          </DropdownMenuItem>
                          
                          <DropdownMenuItem 
                            onClick={() => handleUserAction(user.id, 'suspend', user)}
                            className={`${themeClasses.dropdownItem} cursor-pointer hover:bg-opacity-80 transition-colors duration-200 px-3 py-2`}
                          >
                            {user.status === 'Suspended' ? (
                              <>
                                <CheckCircle className={`h-4 w-4 mr-2 ${isDarkMode ? 'text-green-400' : 'text-green-600'}`} />
                                <span className="text-sm">Reactivate Account</span>
                              </>
                            ) : (
                              <>
                                <UserX className={`h-4 w-4 mr-2 ${isDarkMode ? 'text-orange-400' : 'text-orange-600'}`} />
                                <span className="text-sm">Suspend Account</span>
                              </>
                            )}
                          </DropdownMenuItem>
                          
                          {(user.status === 'Payment Due' || user.plan === 'Free Trial') && (
                            <DropdownMenuItem 
                              onClick={() => handleUserAction(user.id, 'payment_reminder', user)}
                              className={`${themeClasses.dropdownItem} cursor-pointer hover:bg-opacity-80 transition-colors duration-200 px-3 py-2`}
                            >
                              <CreditCard className={`h-4 w-4 mr-2 ${isDarkMode ? 'text-yellow-400' : 'text-yellow-600'}`} />
                              <span className="text-sm">Send Payment Reminder</span>
                            </DropdownMenuItem>
                          )}
                          
                          <DropdownMenuItem 
                            onClick={() => handleUserAction(user.id, 'reset_password', user)}
                            className={`${themeClasses.dropdownItem} cursor-pointer hover:bg-opacity-80 transition-colors duration-200 px-3 py-2`}
                          >
                            <Key className={`h-4 w-4 mr-2 ${isDarkMode ? 'text-purple-400' : 'text-purple-600'}`} />
                            <span className="text-sm">Reset Password</span>
                          </DropdownMenuItem>
                          
                          {user.plan !== 'Premium' && (
                            <DropdownMenuItem 
                              onClick={() => handleUserAction(user.id, 'upgrade_plan', user)}
                              className={`${themeClasses.dropdownItem} cursor-pointer hover:bg-opacity-80 transition-colors duration-200 px-3 py-2`}
                            >
                              <TrendingUp className={`h-4 w-4 mr-2 ${isDarkMode ? 'text-green-400' : 'text-green-600'}`} />
                              <span className="text-sm">Upgrade Plan</span>
                            </DropdownMenuItem>
                          )}
                          
                          <DropdownMenuSeparator className={isDarkMode ? 'bg-gray-600' : 'bg-gray-200'} />
                          
                          <DropdownMenuItem 
                            onClick={() => handleUserAction(user.id, 'archive', user)}
                            className={`${themeClasses.dropdownItem} cursor-pointer hover:bg-opacity-80 transition-colors duration-200 px-3 py-2 text-red-500 hover:text-red-600`}
                          >
                            <Trash2 className="h-4 w-4 mr-2" />
                            <span className="text-sm">Archive User</span>
                          </DropdownMenuItem>
                        </DropdownMenuContent>
                      </DropdownMenu>
                    </div>
                  </div>
                ))}
              </div>

              {/* Pagination Controls */}
              <div className={`flex items-center justify-between mt-6 pt-4 border-t ${themeClasses.border}`}>
                <div className={`text-sm ${themeClasses.secondaryText}`}>
                  Showing 1-10 of 47 users
                </div>
                <div className="flex items-center gap-2">
                  <Button size="sm" variant="outline" disabled className={themeClasses.selectTrigger}>
                    Previous
                  </Button>
                  <div className="flex items-center gap-1">
                    <Button size="sm" variant="outline" className={`w-8 h-8 p-0 ${isDarkMode ? 'bg-blue-600 text-white border-blue-600' : 'bg-blue-600 text-white border-blue-600'}`}>
                      1
                    </Button>
                    <Button size="sm" variant="outline" className={`w-8 h-8 p-0 ${themeClasses.selectTrigger}`}>
                      2
                    </Button>
                    <Button size="sm" variant="outline" className={`w-8 h-8 p-0 ${themeClasses.selectTrigger}`}>
                      3
                    </Button>
                    <span className={`px-2 ${themeClasses.secondaryText}`}>...</span>
                    <Button size="sm" variant="outline" className={`w-8 h-8 p-0 ${themeClasses.selectTrigger}`}>
                      5
                    </Button>
                  </div>
                  <Button size="sm" variant="outline" className={themeClasses.selectTrigger}>
                    Next
                  </Button>
                </div>
              </div>
            </div>
          </CardContent>
        </Card>
      );
    }

    // Trial Management Dashboard
    if (activeSection === 'trials') {
      return (
        <Card className={`${themeClasses.analyticsCard} backdrop-blur-sm`}>
          <CardHeader className={`pb-6 border-b ${themeClasses.border}`}>
            <div className="flex items-center justify-between">
              <div className="flex items-center gap-3">
                <div className={`p-2 rounded-lg ${isDarkMode ? 'bg-gradient-to-br from-orange-900/50 to-amber-900/50 text-orange-400' : 'bg-gradient-to-br from-orange-100 to-amber-100 text-orange-600'}`}>
                  <Clock className="h-6 w-6" />
                </div>
                <div>
                  <CardTitle className={`${themeClasses.primaryText} text-2xl font-bold`}>
                    Trial Management
                  </CardTitle>
                  <CardDescription className={`${themeClasses.secondaryText} text-base`}>
                    Free trial tracking, conversion rates, and user engagement analytics
                  </CardDescription>
                </div>
              </div>
              <div className="flex items-center gap-3">
                <Select value={dateRange} onValueChange={setDateRange}>
                  <SelectTrigger className={`w-32 ${themeClasses.selectTrigger}`}>
                    <SelectValue />
                  </SelectTrigger>
                  <SelectContent className={themeClasses.selectContent}>
                    <SelectItem value="7d">Last 7 days</SelectItem>
                    <SelectItem value="30d">Last 30 days</SelectItem>
                    <SelectItem value="90d">Last 90 days</SelectItem>
                    <SelectItem value="1y">Last year</SelectItem>
                  </SelectContent>
                </Select>
                <Button size="sm" variant="outline" onClick={() => exportData('trial-management-report')}>
                  <Download className="h-3 w-3 mr-1" />
                  Export
                </Button>
              </div>
            </div>
          </CardHeader>
          
          {/* User Management Navigation Tabs */}
          <div className={`px-6 py-3 border-b ${themeClasses.border}`}>
            <nav className="flex space-x-8" aria-label="User Management Tabs">
              <button
                onClick={() => setActiveSection('users')}
                className={`py-2 px-1 border-b-2 font-medium text-sm flex items-center gap-2 ${
                  activeSection === 'users'
                    ? `border-blue-500 ${isDarkMode ? 'text-blue-400' : 'text-blue-600'}`
                    : `border-transparent ${themeClasses.secondaryText} hover:${themeClasses.primaryText} hover:border-gray-300`
                }`}
              >
                <Users className="h-4 w-4" />
                User Analytics
              </button>
              <button
                onClick={() => setActiveSection('trials')}
                className={`py-2 px-1 border-b-2 font-medium text-sm flex items-center gap-2 ${
                  activeSection === 'trials'
                    ? `border-blue-500 ${isDarkMode ? 'text-blue-400' : 'text-blue-600'}`
                    : `border-transparent ${themeClasses.secondaryText} hover:${themeClasses.primaryText} hover:border-gray-300`
                }`}
              >
                <Clock className="h-4 w-4" />
                Trial Management
              </button>
              <button
                onClick={() => setActiveSection('onboarding')}
                className={`py-2 px-1 border-b-2 font-medium text-sm flex items-center gap-2 ${
                  activeSection === 'onboarding'
                    ? `border-blue-500 ${isDarkMode ? 'text-blue-400' : 'text-blue-600'}`
                    : `border-transparent ${themeClasses.secondaryText} hover:${themeClasses.primaryText} hover:border-gray-300`
                }`}
              >
                <UserCheck className="h-4 w-4" />
                User Onboarding
              </button>
              <button
                onClick={() => setActiveSection('authentication')}
                className={`py-2 px-1 border-b-2 font-medium text-sm flex items-center gap-2 ${
                  activeSection === 'authentication'
                    ? `border-blue-500 ${isDarkMode ? 'text-blue-400' : 'text-blue-600'}`
                    : `border-transparent ${themeClasses.secondaryText} hover:${themeClasses.primaryText} hover:border-gray-300`
                }`}
              >
                <Shield className="h-4 w-4" />
                Auth Tracking
              </button>
            </nav>
          </div>
          
          <CardContent className="space-y-8 pt-6">
            {/* Trial Overview Metrics */}
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
              <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-orange-700/50 bg-gradient-to-br from-orange-900/20 to-orange-800/10 backdrop-blur-sm' : 'border-orange-200 bg-gradient-to-br from-orange-50 to-orange-100/50'}`}>
                <div className="flex items-center justify-between mb-4">
                  <div className={`p-2 rounded-lg ${isDarkMode ? 'bg-orange-600/20 text-orange-400' : 'bg-orange-100 text-orange-600'}`}>
                    <UserPlus className="h-4 w-4" />
                  </div>
                  <div className={`text-xs ${isDarkMode ? 'text-green-400' : 'text-green-600'} flex items-center gap-1`}>
                    <TrendingUp className="h-3 w-3" />
                    +18.5%
                  </div>
                </div>
                <div>
                  <div className={`text-2xl font-bold ${themeClasses.primaryText} mb-1`}>
                    {trialAnalytics?.totalTrials || 156}
                  </div>
                  <div className={`text-sm ${themeClasses.secondaryText}`}>Active Trials</div>
                  <div className={`text-xs ${themeClasses.secondaryText} mt-2`}>
                    {trialAnalytics?.newTrials || 23} started this week
                  </div>
                </div>
              </div>

              <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-green-700/50 bg-gradient-to-br from-green-900/20 to-green-800/10 backdrop-blur-sm' : 'border-green-200 bg-gradient-to-br from-green-50 to-green-100/50'}`}>
                <div className="flex items-center justify-between mb-4">
                  <div className={`p-2 rounded-lg ${isDarkMode ? 'bg-green-600/20 text-green-400' : 'bg-green-100 text-green-600'}`}>
                    <TrendingUp className="h-4 w-4" />
                  </div>
                  <div className={`text-xs ${isDarkMode ? 'text-green-400' : 'text-green-600'} flex items-center gap-1`}>
                    <TrendingUp className="h-3 w-3" />
                    +12.3%
                  </div>
                </div>
                <div>
                  <div className={`text-2xl font-bold ${themeClasses.primaryText} mb-1`}>
                    {trialAnalytics?.conversionRate || 34}%
                  </div>
                  <div className={`text-sm ${themeClasses.secondaryText}`}>Conversion Rate</div>
                  <div className={`text-xs ${themeClasses.secondaryText} mt-2`}>
                    {trialAnalytics?.conversions || 53} converted this month
                  </div>
                </div>
              </div>

              <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-purple-700/50 bg-gradient-to-br from-purple-900/20 to-purple-800/10 backdrop-blur-sm' : 'border-purple-200 bg-gradient-to-br from-purple-50 to-purple-100/50'}`}>
                <div className="flex items-center justify-between mb-4">
                  <div className={`p-2 rounded-lg ${isDarkMode ? 'bg-purple-600/20 text-purple-400' : 'bg-purple-100 text-purple-600'}`}>
                    <Clock className="h-4 w-4" />
                  </div>
                  <div className={`text-xs ${isDarkMode ? 'text-red-400' : 'text-red-600'} flex items-center gap-1`}>
                    <TrendingDown className="h-3 w-3" />
                    -3.2%
                  </div>
                </div>
                <div>
                  <div className={`text-2xl font-bold ${themeClasses.primaryText} mb-1`}>
                    18.2
                  </div>
                  <div className={`text-sm ${themeClasses.secondaryText}`}>Avg. Trial Days</div>
                  <div className={`text-xs ${themeClasses.secondaryText} mt-2`}>
                    Before conversion or expiry
                  </div>
                </div>
              </div>

              <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-blue-700/50 bg-gradient-to-br from-blue-900/20 to-blue-800/10 backdrop-blur-sm' : 'border-blue-200 bg-gradient-to-br from-blue-50 to-blue-100/50'}`}>
                <div className="flex items-center justify-between mb-4">
                  <div className={`p-2 rounded-lg ${isDarkMode ? 'bg-blue-600/20 text-blue-400' : 'bg-blue-100 text-blue-600'}`}>
                    <AlertTriangle className="h-4 w-4" />
                  </div>
                  <div className={`text-xs ${isDarkMode ? 'text-orange-400' : 'text-orange-600'} flex items-center gap-1`}>
                    <TrendingUp className="h-3 w-3" />
                    +5.7%
                  </div>
                </div>
                <div>
                  <div className={`text-2xl font-bold ${themeClasses.primaryText} mb-1`}>
                    {trialAnalytics?.expiringTrials || 24}
                  </div>
                  <div className={`text-sm ${themeClasses.secondaryText}`}>Expiring Soon</div>
                  <div className={`text-xs ${themeClasses.secondaryText} mt-2`}>
                    Within next 7 days
                  </div>
                </div>
              </div>
            </div>

            {/* Trial Status Chart */}
            <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-gray-700 bg-gradient-to-br from-gray-900/30 to-gray-800/20 backdrop-blur-sm' : 'border-gray-200 bg-gradient-to-br from-gray-50/50 to-white/50'}`}>
              <div className="flex items-center justify-between mb-6">
                <div>
                  <h3 className={`font-semibold ${themeClasses.primaryText} text-lg mb-2`}>Trial Activity Timeline</h3>
                  <p className={`text-sm ${themeClasses.secondaryText}`}>New trials, conversions, and expirations over time</p>
                </div>
              </div>
              {/* Timeline Chart */}
              <div className="h-80 relative px-4">
                {/* Chart Area */}
                <div className="h-64 flex items-end justify-between gap-3 mb-6">
                  {[
                    { date: '1/25', newTrials: 12, conversions: 3, expirations: 5 },
                    { date: '1/26', newTrials: 8, conversions: 2, expirations: 3 },
                    { date: '1/27', newTrials: 15, conversions: 4, expirations: 7 },
                    { date: '1/28', newTrials: 20, conversions: 6, expirations: 4 },
                    { date: '1/29', newTrials: 18, conversions: 5, expirations: 8 },
                    { date: '1/30', newTrials: 25, conversions: 8, expirations: 6 },
                    { date: '1/31', newTrials: 22, conversions: 7, expirations: 5 }
                  ].map((day, index) => {
                    const maxTotal = 35;
                    const total = day.newTrials + day.conversions + day.expirations;
                    const barHeight = Math.max(20, (total / maxTotal) * 200);
                    
                    const newTrialsPercent = (day.newTrials / total) * 100;
                    const conversionsPercent = (day.conversions / total) * 100;
                    const expirationsPercent = (day.expirations / total) * 100;

                    return (
                      <div key={index} className="flex flex-col items-center">
                        {/* Bar Stack */}
                        <div 
                          className="w-12 relative group cursor-pointer"
                          style={{ height: `${barHeight}px` }}
                        >
                          {/* New Trials (Bottom) */}
                          <div 
                            className={`absolute bottom-0 w-full ${isDarkMode ? 'bg-blue-500' : 'bg-blue-600'} transition-all duration-200 hover:brightness-110 rounded-b-md`}
                            style={{ height: `${newTrialsPercent}%` }}
                            title={`${day.newTrials} new trials`}
                          />
                          
                          {/* Conversions (Middle) */}
                          <div 
                            className={`absolute w-full ${isDarkMode ? 'bg-green-500' : 'bg-green-600'} transition-all duration-200 hover:brightness-110`}
                            style={{ 
                              height: `${conversionsPercent}%`,
                              bottom: `${newTrialsPercent}%`
                            }}
                            title={`${day.conversions} conversions`}
                          />
                          
                          {/* Expirations (Top) */}
                          <div 
                            className={`absolute w-full ${isDarkMode ? 'bg-red-500' : 'bg-red-600'} transition-all duration-200 hover:brightness-110 rounded-t-md`}
                            style={{ 
                              height: `${expirationsPercent}%`,
                              bottom: `${newTrialsPercent + conversionsPercent}%`
                            }}
                            title={`${day.expirations} expired`}
                          />
                          
                          {/* Hover Tooltip */}
                          <div className={`absolute -top-16 left-1/2 transform -translate-x-1/2 px-3 py-2 text-xs rounded-md opacity-0 group-hover:opacity-100 transition-opacity z-10 whitespace-nowrap ${isDarkMode ? 'bg-gray-800 text-white border border-gray-600' : 'bg-white text-gray-800 border border-gray-200 shadow-lg'}`}>
                            <div className="font-medium mb-1">{day.date}</div>
                            <div className="space-y-1">
                              <div className="flex items-center gap-2">
                                <div className="w-2 h-2 bg-blue-500 rounded" />
                                <span>{day.newTrials} new</span>
                              </div>
                              <div className="flex items-center gap-2">
                                <div className="w-2 h-2 bg-green-500 rounded" />
                                <span>{day.conversions} converted</span>
                              </div>
                              <div className="flex items-center gap-2">
                                <div className="w-2 h-2 bg-red-500 rounded" />
                                <span>{day.expirations} expired</span>
                              </div>
                            </div>
                          </div>
                        </div>
                        
                        {/* Date Label */}
                        <div className={`text-xs mt-3 ${themeClasses.secondaryText} font-medium`}>
                          {day.date}
                        </div>
                      </div>
                    );
                  })}
                </div>
                
                {/* Legend */}
                <div className="flex items-center justify-center gap-8">
                  <div className="flex items-center gap-2">
                    <div className={`w-4 h-4 rounded-sm ${isDarkMode ? 'bg-blue-500' : 'bg-blue-600'}`} />
                    <span className={`text-sm font-medium ${themeClasses.primaryText}`}>New Trials</span>
                  </div>
                  <div className="flex items-center gap-2">
                    <div className={`w-4 h-4 rounded-sm ${isDarkMode ? 'bg-green-500' : 'bg-green-600'}`} />
                    <span className={`text-sm font-medium ${themeClasses.primaryText}`}>Conversions</span>
                  </div>
                  <div className="flex items-center gap-2">
                    <div className={`w-4 h-4 rounded-sm ${isDarkMode ? 'bg-red-500' : 'bg-red-600'}`} />
                    <span className={`text-sm font-medium ${themeClasses.primaryText}`}>Expirations</span>
                  </div>
                </div>
              </div>
            </div>

            {/* Active Trials Table */}
            <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-gray-700 bg-gradient-to-br from-gray-900/30 to-gray-800/20 backdrop-blur-sm' : 'border-gray-200 bg-gradient-to-br from-gray-50/50 to-white/50'}`}>
              <div className="flex items-center justify-between mb-6">
                <div>
                  <h3 className={`font-semibold ${themeClasses.primaryText} text-lg mb-2`}>All Trials Management</h3>
                  <p className={`text-sm ${themeClasses.secondaryText}`}>Complete overview of all trial subscriptions with detailed status tracking</p>
                </div>
                <div className="flex items-center gap-3">
                  <div className="flex items-center gap-2">
                    <Search className={`h-4 w-4 ${themeClasses.secondaryText}`} />
                    <input
                      type="text"
                      placeholder="Search trials..."
                      className={`px-3 py-2 text-sm border rounded-md ${isDarkMode ? 'bg-gray-800 border-gray-600 text-white placeholder-gray-400' : 'bg-white border-gray-300 text-gray-900 placeholder-gray-500'} focus:outline-none focus:ring-2 focus:ring-blue-500`}
                    />
                  </div>
                  <Select defaultValue="all">
                    <SelectTrigger className={`w-36 ${themeClasses.selectTrigger}`}>
                      <SelectValue />
                    </SelectTrigger>
                    <SelectContent className={themeClasses.selectContent}>
                      <SelectItem value="all">All Status</SelectItem>
                      <SelectItem value="active">Active</SelectItem>
                      <SelectItem value="expiring">Expiring Soon</SelectItem>
                      <SelectItem value="expired">Expired</SelectItem>
                      <SelectItem value="converted">Converted</SelectItem>
                    </SelectContent>
                  </Select>
                </div>
              </div>

              {/* Trials Table */}
              <div className="overflow-x-auto">
                <table className="w-full">
                  <thead>
                    <tr className={`border-b ${themeClasses.border}`}>
                      <th className={`text-left py-3 px-4 font-medium ${themeClasses.primaryText}`}>User</th>
                      <th className={`text-left py-3 px-4 font-medium ${themeClasses.primaryText}`}>Organization</th>
                      <th className={`text-left py-3 px-4 font-medium ${themeClasses.primaryText}`}>Start Date</th>
                      <th className={`text-left py-3 px-4 font-medium ${themeClasses.primaryText}`}>Expiry Date</th>
                      <th className={`text-left py-3 px-4 font-medium ${themeClasses.primaryText}`}>Days Left</th>
                      <th className={`text-left py-3 px-4 font-medium ${themeClasses.primaryText}`}>Status</th>
                      <th className={`text-left py-3 px-4 font-medium ${themeClasses.primaryText}`}>Usage</th>
                      <th className={`text-right py-3 px-4 font-medium ${themeClasses.primaryText}`}>Actions</th>
                    </tr>
                  </thead>
                  <tbody>
                    {[
                      {
                        id: 1,
                        user: { id: 1, name: "Rev. James Carter", email: "james@gracechurch.org", avatar: "JC" },
                        organization: "Grace Community Church",
                        startDate: "2025-01-15",
                        expiryDate: "2025-02-14",
                        daysLeft: 14,
                        status: "active",
                        usage: { sessions: 23, features: 8 },
                        plan: "Professional"
                      },
                      {
                        id: 2,
                        user: { id: 2, name: "Pastor Sarah Wilson", email: "sarah@faithhope.church", avatar: "SW" },
                        organization: "Faith & Hope Ministry",
                        startDate: "2025-01-10",
                        expiryDate: "2025-02-09",
                        daysLeft: 9,
                        status: "expiring",
                        usage: { sessions: 45, features: 12 },
                        plan: "Premium"
                      },
                      {
                        id: 3,
                        user: { id: 3, name: "Dr. Michael Rodriguez", email: "mike@newlife.church", avatar: "MR" },
                        organization: "New Life Church",
                        startDate: "2025-01-20",
                        expiryDate: "2025-02-19",
                        daysLeft: 19,
                        status: "active",
                        usage: { sessions: 12, features: 5 },
                        plan: "Basic"
                      },
                      {
                        id: 4,
                        user: { id: 4, name: "Rev. Lisa Thompson", email: "lisa@unitychurch.net", avatar: "LT" },
                        organization: "Unity Baptist Church",
                        startDate: "2024-12-28",
                        expiryDate: "2025-01-27",
                        daysLeft: -4,
                        status: "expired",
                        usage: { sessions: 8, features: 3 },
                        plan: "Basic"
                      },
                      {
                        id: 5,
                        user: { id: 5, name: "Pastor David Kim", email: "david@crossroads.church", avatar: "DK" },
                        organization: "Crossroads Fellowship",
                        startDate: "2025-01-05",
                        expiryDate: "2025-02-04",
                        daysLeft: 4,
                        status: "expiring",
                        usage: { sessions: 67, features: 15 },
                        plan: "Premium"
                      },
                      {
                        id: 6,
                        user: { id: 6, name: "Rev. Maria Santos", email: "maria@holyspirit.org", avatar: "MS" },
                        organization: "Holy Spirit Cathedral",
                        startDate: "2025-01-12",
                        expiryDate: "2025-02-11",
                        daysLeft: 11,
                        status: "converted",
                        usage: { sessions: 89, features: 18 },
                        plan: "Enterprise"
                      }
                    ].map((trial) => {
                      const getStatusColor = (status: string) => {
                        switch (status) {
                          case 'active': return isDarkMode ? 'bg-green-900/30 text-green-400 border-green-700' : 'bg-green-100 text-green-800 border-green-200';
                          case 'expiring': return isDarkMode ? 'bg-orange-900/30 text-orange-400 border-orange-700' : 'bg-orange-100 text-orange-800 border-orange-200';
                          case 'expired': return isDarkMode ? 'bg-red-900/30 text-red-400 border-red-700' : 'bg-red-100 text-red-800 border-red-200';
                          case 'converted': return isDarkMode ? 'bg-blue-900/30 text-blue-400 border-blue-700' : 'bg-blue-100 text-blue-800 border-blue-200';
                          default: return isDarkMode ? 'bg-gray-900/30 text-gray-400 border-gray-700' : 'bg-gray-100 text-gray-800 border-gray-200';
                        }
                      };

                      const getDaysLeftColor = (daysLeft: number) => {
                        if (daysLeft < 0) return isDarkMode ? 'text-red-400' : 'text-red-600';
                        if (daysLeft <= 7) return isDarkMode ? 'text-orange-400' : 'text-orange-600';
                        if (daysLeft <= 14) return isDarkMode ? 'text-yellow-400' : 'text-yellow-600';
                        return themeClasses.primaryText;
                      };

                      return (
                        <tr key={trial.id} className={`border-b ${themeClasses.border} hover:${isDarkMode ? 'bg-gray-800/50' : 'bg-gray-50/50'} transition-colors`}>
                          <td className="py-4 px-4">
                            <div className="flex items-center gap-3">
                              <div className={`w-10 h-10 rounded-full flex items-center justify-center text-sm font-medium ${isDarkMode ? 'bg-blue-600/20 text-blue-400' : 'bg-blue-100 text-blue-600'}`}>
                                {trial.user.avatar}
                              </div>
                              <div>
                                <div className={`font-medium ${themeClasses.primaryText}`}>{trial.user.name}</div>
                                <div className={`text-sm ${themeClasses.secondaryText}`}>{trial.user.email}</div>
                              </div>
                            </div>
                          </td>
                          <td className={`py-4 px-4 ${themeClasses.primaryText}`}>
                            <div className="flex items-center gap-2">
                              <Church className="h-4 w-4 opacity-60" />
                              {trial.organization}
                            </div>
                          </td>
                          <td className={`py-4 px-4 ${themeClasses.secondaryText}`}>
                            {new Date(trial.startDate).toLocaleDateString()}
                          </td>
                          <td className={`py-4 px-4 ${themeClasses.secondaryText}`}>
                            {new Date(trial.expiryDate).toLocaleDateString()}
                          </td>
                          <td className={`py-4 px-4 font-medium ${getDaysLeftColor(trial.daysLeft)}`}>
                            {trial.daysLeft < 0 ? `${Math.abs(trial.daysLeft)} days ago` : `${trial.daysLeft} days`}
                          </td>
                          <td className="py-4 px-4">
                            <Badge className={`${getStatusColor(trial.status)} capitalize`}>
                              {trial.status}
                            </Badge>
                          </td>
                          <td className={`py-4 px-4 ${themeClasses.secondaryText}`}>
                            <div className="text-sm">
                              <div>{trial.usage.sessions} sessions</div>
                              <div className="text-xs opacity-75">{trial.usage.features} features used</div>
                            </div>
                          </td>
                          <td className="py-4 px-4">
                            <DropdownMenu>
                              <DropdownMenuTrigger asChild>
                                <Button 
                                  variant="ghost" 
                                  size="sm"
                                  className={`h-8 w-8 p-0 ${themeClasses.buttonSecondary}`}
                                >
                                  <Settings className="h-4 w-4" />
                                </Button>
                              </DropdownMenuTrigger>
                              <DropdownMenuContent className={themeClasses.dropdownBackground} align="end">
                                <DropdownMenuLabel className={themeClasses.primaryText}>Trial Actions</DropdownMenuLabel>
                                <DropdownMenuSeparator className={themeClasses.border} />
                                
                                <DropdownMenuItem 
                                  className={`${themeClasses.dropdownItem} cursor-pointer`}
                                  onClick={() => handleViewDetails(trial)}
                                >
                                  <Eye className="h-4 w-4 mr-2" />
                                  View Details
                                </DropdownMenuItem>
                                
                                {trial.status === 'active' && (
                                  <>
                                    <DropdownMenuItem 
                                      className={`${themeClasses.dropdownItem} cursor-pointer text-blue-600`}
                                      onClick={() => handleExtendTrial(trial)}
                                    >
                                      <Clock className="h-4 w-4 mr-2" />
                                      Extend Trial
                                    </DropdownMenuItem>
                                    <DropdownMenuItem 
                                      className={`${themeClasses.dropdownItem} cursor-pointer text-green-600`}
                                      onClick={() => handleConvertToPaid(trial)}
                                    >
                                      <CreditCard className="h-4 w-4 mr-2" />
                                      Convert to Paid
                                    </DropdownMenuItem>
                                  </>
                                )}
                                
                                {trial.status === 'expiring' && (
                                  <>
                                    <DropdownMenuItem 
                                      className={`${themeClasses.dropdownItem} cursor-pointer text-blue-600`}
                                      onClick={() => handleExtendTrial(trial)}
                                    >
                                      <Clock className="h-4 w-4 mr-2" />
                                      Extend Trial
                                    </DropdownMenuItem>
                                    <DropdownMenuItem 
                                      className={`${themeClasses.dropdownItem} cursor-pointer text-green-600`}
                                      onClick={() => handleConvertToPaid(trial)}
                                    >
                                      <CreditCard className="h-4 w-4 mr-2" />
                                      Convert to Paid
                                    </DropdownMenuItem>
                                    <DropdownMenuItem 
                                      className={`${themeClasses.dropdownItem} cursor-pointer text-orange-600`}
                                      onClick={() => handleSendReminder(trial)}
                                    >
                                      <Bell className="h-4 w-4 mr-2" />
                                      Send Reminder
                                    </DropdownMenuItem>
                                  </>
                                )}
                                
                                {trial.status === 'expired' && (
                                  <>
                                    <DropdownMenuItem 
                                      className={`${themeClasses.dropdownItem} cursor-pointer text-blue-600`}
                                      onClick={() => handleReactivateTrial(trial)}
                                    >
                                      <RotateCcw className="h-4 w-4 mr-2" />
                                      Reactivate Trial
                                    </DropdownMenuItem>
                                    <DropdownMenuItem 
                                      className={`${themeClasses.dropdownItem} cursor-pointer text-green-600`}
                                      onClick={() => handleConvertToPaid(trial)}
                                    >
                                      <CreditCard className="h-4 w-4 mr-2" />
                                      Convert to Paid
                                    </DropdownMenuItem>
                                  </>
                                )}
                                
                                {trial.status === 'converted' && (
                                  <DropdownMenuItem 
                                    className={`${themeClasses.dropdownItem} cursor-pointer text-blue-600`}
                                    onClick={() => handleViewSubscription(trial)}
                                  >
                                    <ExternalLink className="h-4 w-4 mr-2" />
                                    View Subscription
                                  </DropdownMenuItem>
                                )}
                                
                                <DropdownMenuSeparator className={themeClasses.border} />
                                
                                <DropdownMenuItem 
                                  className={`${themeClasses.dropdownItem} cursor-pointer text-purple-600`}
                                  onClick={() => handleSendMessage(trial)}
                                >
                                  <Mail className="h-4 w-4 mr-2" />
                                  Send Message
                                </DropdownMenuItem>
                                
                                <DropdownMenuItem 
                                  className={`${themeClasses.dropdownItem} cursor-pointer`}
                                  onClick={() => handleExportData(trial)}
                                >
                                  <Download className="h-4 w-4 mr-2" />
                                  Export Data
                                </DropdownMenuItem>
                                
                                {trial.status !== 'converted' && (
                                  <DropdownMenuItem 
                                    className={`${themeClasses.dropdownItem} cursor-pointer text-red-600`}
                                    onClick={() => handleCancelTrial(trial)}
                                  >
                                    <XCircle className="h-4 w-4 mr-2" />
                                    Cancel Trial
                                  </DropdownMenuItem>
                                )}
                              </DropdownMenuContent>
                            </DropdownMenu>
                          </td>
                        </tr>
                      );
                    })}
                  </tbody>
                </table>
              </div>

              {/* Pagination */}
              <div className={`flex items-center justify-between mt-6 pt-4 border-t ${themeClasses.border}`}>
                <div className={`text-sm ${themeClasses.secondaryText}`}>
                  Showing 6 of 156 trial subscriptions
                </div>
                <div className="flex items-center gap-2">
                  <Button size="sm" variant="outline" disabled className={themeClasses.selectTrigger}>
                    Previous
                  </Button>
                  <div className="flex items-center gap-1">
                    <Button size="sm" variant="outline" className={`w-8 h-8 p-0 ${isDarkMode ? 'bg-blue-600 text-white border-blue-600' : 'bg-blue-600 text-white border-blue-600'}`}>
                      1
                    </Button>
                    <Button size="sm" variant="outline" className={`w-8 h-8 p-0 ${themeClasses.selectTrigger}`}>
                      2
                    </Button>
                    <Button size="sm" variant="outline" className={`w-8 h-8 p-0 ${themeClasses.selectTrigger}`}>
                      3
                    </Button>
                    <span className={`px-2 ${themeClasses.secondaryText}`}>...</span>
                    <Button size="sm" variant="outline" className={`w-8 h-8 p-0 ${themeClasses.selectTrigger}`}>
                      26
                    </Button>
                  </div>
                  <Button size="sm" variant="outline" className={themeClasses.selectTrigger}>
                    Next
                  </Button>
                </div>
              </div>
            </div>
            
            {/* Trial Management Dialogs */}
            
            {/* Extend Trial Dialog */}
            <Dialog open={showExtendDialog} onOpenChange={setShowExtendDialog}>
              <DialogContent className={`${isDarkMode ? 'bg-gray-900 border-gray-700' : 'bg-white border-gray-200'}`}>
                <DialogHeader>
                  <DialogTitle className={themeClasses.primaryText}>Extend Trial</DialogTitle>
                  <DialogDescription className={themeClasses.secondaryText}>
                    Extend trial for {selectedTrial?.user.name}
                  </DialogDescription>
                </DialogHeader>
                <div className="space-y-4">
                  <div>
                    <Label htmlFor="extensionDays" className={themeClasses.primaryText}>Number of Days</Label>
                    <Input
                      id="extensionDays"
                      type="number"
                      placeholder="Enter days to extend"
                      value={extensionDays}
                      onChange={(e) => setExtensionDays(e.target.value)}
                      className={`mt-1 ${isDarkMode ? 'bg-gray-800 border-gray-600' : 'bg-white border-gray-300'}`}
                    />
                  </div>
                  <div className={`text-sm ${themeClasses.secondaryText}`}>
                    Current expiry: {selectedTrial && new Date(selectedTrial.expiryDate).toLocaleDateString()}
                  </div>
                </div>
                <DialogFooter>
                  <Button variant="outline" onClick={() => setShowExtendDialog(false)}>
                    Cancel
                  </Button>
                  <Button onClick={confirmExtendTrial} className="bg-blue-600 hover:bg-blue-700">
                    Extend Trial
                  </Button>
                </DialogFooter>
              </DialogContent>
            </Dialog>

            {/* Convert to Paid Dialog */}
            <Dialog open={showConvertDialog} onOpenChange={setShowConvertDialog}>
              <DialogContent className={`${isDarkMode ? 'bg-gray-900 border-gray-700' : 'bg-white border-gray-200'}`}>
                <DialogHeader>
                  <DialogTitle className={themeClasses.primaryText}>Convert to Paid Plan</DialogTitle>
                  <DialogDescription className={themeClasses.secondaryText}>
                    Convert {selectedTrial?.user.name}'s trial to a paid subscription
                  </DialogDescription>
                </DialogHeader>
                <div className="space-y-4">
                  <div>
                    <Label htmlFor="planSelect" className={themeClasses.primaryText}>Select Plan</Label>
                    <Select value={selectedPlan} onValueChange={setSelectedPlan}>
                      <SelectTrigger className={`mt-1 ${isDarkMode ? 'bg-gray-800 border-gray-600' : 'bg-white border-gray-300'}`}>
                        <SelectValue placeholder="Choose a plan" />
                      </SelectTrigger>
                      <SelectContent>
                        <SelectItem value="basic">Basic - $29/month</SelectItem>
                        <SelectItem value="professional">Professional - $59/month</SelectItem>
                        <SelectItem value="premium">Premium - $99/month</SelectItem>
                        <SelectItem value="enterprise">Enterprise - $199/month</SelectItem>
                      </SelectContent>
                    </Select>
                  </div>
                  <div className={`text-sm ${themeClasses.secondaryText}`}>
                    This will immediately convert the trial and start billing.
                  </div>
                </div>
                <DialogFooter>
                  <Button variant="outline" onClick={() => setShowConvertDialog(false)}>
                    Cancel
                  </Button>
                  <Button onClick={confirmConvertTrial} className="bg-green-600 hover:bg-green-700">
                    Convert to Paid
                  </Button>
                </DialogFooter>
              </DialogContent>
            </Dialog>

            {/* Send Message Dialog */}
            <Dialog open={showMessageDialog} onOpenChange={setShowMessageDialog}>
              <DialogContent className={`${isDarkMode ? 'bg-gray-900 border-gray-700' : 'bg-white border-gray-200'}`}>
                <DialogHeader>
                  <DialogTitle className={themeClasses.primaryText}>Send Message</DialogTitle>
                  <DialogDescription className={themeClasses.secondaryText}>
                    Send a message to {selectedTrial?.user.name}
                  </DialogDescription>
                </DialogHeader>
                <div className="space-y-4">
                  <div>
                    <Label htmlFor="messageContent" className={themeClasses.primaryText}>Message</Label>
                    <Textarea
                      id="messageContent"
                      placeholder="Enter your message..."
                      value={messageContent}
                      onChange={(e) => setMessageContent(e.target.value)}
                      rows={4}
                      className={`mt-1 ${isDarkMode ? 'bg-gray-800 border-gray-600' : 'bg-white border-gray-300'}`}
                    />
                  </div>
                </div>
                <DialogFooter>
                  <Button variant="outline" onClick={() => setShowMessageDialog(false)}>
                    Cancel
                  </Button>
                  <Button onClick={confirmSendMessage} className="bg-purple-600 hover:bg-purple-700">
                    Send Message
                  </Button>
                </DialogFooter>
              </DialogContent>
            </Dialog>

            {/* Cancel Trial Dialog */}
            <Dialog open={showCancelDialog} onOpenChange={setShowCancelDialog}>
              <DialogContent className={`${isDarkMode ? 'bg-gray-900 border-gray-700' : 'bg-white border-gray-200'}`}>
                <DialogHeader>
                  <DialogTitle className={themeClasses.primaryText}>Cancel Trial</DialogTitle>
                  <DialogDescription className={themeClasses.secondaryText}>
                    Are you sure you want to cancel {selectedTrial?.user.name}'s trial?
                  </DialogDescription>
                </DialogHeader>
                <div className={`p-4 rounded-md ${isDarkMode ? 'bg-red-900/20 border border-red-800' : 'bg-red-50 border border-red-200'}`}>
                  <div className={`text-sm ${isDarkMode ? 'text-red-400' : 'text-red-600'}`}>
                    <strong>Warning:</strong> This action cannot be undone. The user will lose access immediately.
                  </div>
                </div>
                <DialogFooter>
                  <Button variant="outline" onClick={() => setShowCancelDialog(false)}>
                    Keep Trial
                  </Button>
                  <Button onClick={confirmCancelTrial} variant="destructive">
                    Cancel Trial
                  </Button>
                </DialogFooter>
              </DialogContent>
            </Dialog>
          </CardContent>
        </Card>
      );
    }

    // User Onboarding Dashboard
    if (activeSection === 'onboarding') {
      return (
