              <div className={`p-6 rounded-xl border ${isDarkMode ? 'border-gray-700 bg-gradient-to-br from-green-900/20 to-blue-900/20 backdrop-blur-sm' : 'border-gray-200 bg-gradient-to-br from-green-50/50 to-blue-50/50'}`}>
                <h3 className={`font-semibold ${themeClasses.primaryText} text-lg mb-6`}>Revenue Forecasting</h3>
                <div className="space-y-4">
                  <div className={`p-4 rounded-lg border ${isDarkMode ? 'border-gray-600 bg-gray-700/30' : 'border-gray-200 bg-white/50'}`}>
                    <div className="flex items-center gap-3 mb-3">
                      <Target className={`h-5 w-5 ${isDarkMode ? 'text-green-400' : 'text-green-600'}`} />
                      <h4 className={`font-medium ${themeClasses.primaryText} text-sm`}>Next Quarter</h4>
