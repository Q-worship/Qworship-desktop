                    Revenue Analytics
                  </CardTitle>
                  <CardDescription className={`${themeClasses.secondaryText} text-base`}>
                    Financial performance, subscription metrics, and revenue forecasting
                  </CardDescription>
                </div>
              </div>
              <div className="flex items-center gap-3">
                <Select value={dateRange} onValueChange={setDateRange}>
