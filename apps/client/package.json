{
  "name": "@qworship/client",
  "private": true,
  "version": "1.0.1",
  "description": "Qworship Live Console desktop application for live church presentation, Hands-Free Bible, songs, Bible search, and NDI output.",
  "author": "Qworship",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "vite",
    "build": "vite build",
    "patch:vosk-electron-runtime": "node scripts/patch-vosk-electron-runtime.cjs",
    "stage:tigerconnect-runtime": "node scripts/vendor-tigerconnect-runtime.cjs",
    "stage:qworship-ndi-runtime": "node scripts/vendor-qworship-ndi-runtime.cjs",
    "rebuild:desktop-native": "electron-rebuild -f -w better-sqlite3,smart-whisper,onnxruntime-node,grandiose,qworship-ndi,vosk",
    "build:desktop": "vite build && node scripts/patch-vosk-electron-runtime.cjs && node scripts/vendor-tigerconnect-runtime.cjs && node scripts/vendor-qworship-ndi-runtime.cjs && node scripts/prepare-wincodesign-cache.cjs && electron-builder && node scripts/generate-desktop-update-metadata.cjs",
    "build:bible": "node scripts/build-bible-sqlite.js",
    "generate:desktop-update-metadata": "node scripts/generate-desktop-update-metadata.cjs",
    "verify:desktop-update-artifacts": "node scripts/verify-desktop-update-artifacts.cjs",
    "publish:desktop:update": "node scripts/generate-desktop-update-metadata.cjs && node scripts/publish-desktop-update.cjs",
    "postinstall": "node scripts/patch-vosk-electron-runtime.cjs && node scripts/vendor-tigerconnect-runtime.cjs && node scripts/vendor-qworship-ndi-runtime.cjs",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "electron-updater": "^6.8.4",
    "@qworship/shared": "workspace:*",
    "@qworship/types": "workspace:*",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-aspect-ratio": "^1.0.3",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-collapsible": "^1.0.3",
    "@radix-ui/react-context-menu": "^2.1.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-hover-card": "^1.0.7",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-menubar": "^1.0.4",
    "@radix-ui/react-navigation-menu": "^1.1.4",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-toggle": "^1.0.3",
    "@radix-ui/react-toggle-group": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-query": "^5.90.21",
    "@tigerconnect/ffi-napi": "4.0.3-tc3",
    "@tigerconnect/ref-napi": "4.0.0-tc8",
    "axios": "^1.13.6",
    "better-sqlite3": "^9.6.0",
    "bindings": "^1.5.0",
    "canvas-txt": "^4.1.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "debug": "^4.3.7",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "ffi-napi": "npm:@tigerconnect/ffi-napi@4.0.3-tc3",
    "file-uri-to-path": "^2.0.0",
    "fuse.js": "^7.3.0",
    "grandiose": "^0.0.4",
    "lucide-react": "^0.320.0",
    "mammoth": "^1.12.0",
    "ms": "^2.1.3",
    "node-gyp-build": "^4.8.4",
    "obs-websocket-js": "^5.0.3",
    "qworship-ndi": "file:./native/qworship-ndi",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.50.0",
    "recharts": "^3.8.1",
    "ref-array-di": "^1.2.2",
    "ref-napi": "npm:@tigerconnect/ref-napi@4.0.0-tc8",
    "ref-struct-di": "^1.1.1",
    "onnxruntime-node": "^1.20.1",
    "smart-whisper": "^0.8.1",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^0.8.9",
    "vosk": "^0.3.39",
    "words-to-numbers": "^1.5.1",
    "wouter": "^3.9.0",
    "ws": "^8.18.3",
    "zod": "^3.22.4",
    "zustand": "^5.0.0"
  },
  "build": {
    "appId": "com.qworship.liveconsole",
    "productName": "Qworship Live Console",
    "executableName": "Qworship Live Console",
    "artifactName": "${productName} Setup ${version}.${ext}",
    "copyright": "Copyright © 2026 Qworship. All rights reserved.",
    "directories": {
      "output": "release-hfb-mode-fix-v2"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "publisherName": "Qworship",
      "artifactName": "Qworship Live Console Setup ${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "differentialPackage": false,
      "artifactName": "Qworship Live Console Setup ${version}.${ext}",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Qworship Live Console",
      "deleteAppDataOnUninstall": false
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://pub-3fc3537dae154068a167de3a3c875c3e.r2.dev/live-console-updates/win/staged"
      }
    ],
    "extraMetadata": {
      "name": "qworship-live-console"
    },
    "npmRebuild": false,
    "protocols": {
      "name": "qworship-protocol",
      "schemes": [
        "qworship"
      ]
    },
    "asarUnpack": [
      "node_modules/onnxruntime-node/**",
      "node_modules/smart-whisper/**",
      "node_modules/better-sqlite3/**",
      "node_modules/bindings/**",
      "node_modules/file-uri-to-path/**",
      "node_modules/@tigerconnect/**",
      "node_modules/ffi-napi/**",
      "node_modules/ref-napi/**",
      "node_modules/ref-array-di/**",
      "node_modules/ref-struct-di/**",
      "node_modules/grandiose/**",
      "node_modules/qworship-ndi/**",
      "node_modules/vosk/**",
      "dist/data/bibles/**"
    ],
    "afterPack": "scripts/after-pack-stage-native-runtime.cjs",
    "extraResources": [
      {
        "from": "models/",
        "to": "models",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "public/data/bibles",
        "to": "data/bibles",
        "filter": [
          "**/*"
        ]
      }
    ],
    "extraFiles": [
      {
        "from": "bin/${os}",
        "to": "bin",
        "filter": [
          "*"
        ]
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "node_modules/@tigerconnect/**/*",
      "node_modules/ffi-napi/**/*",
      "node_modules/ref-napi/**/*",
      "node_modules/ref-array-di/**/*",
      "node_modules/ref-struct-di/**/*",
      "node_modules/debug/**/*",
      "node_modules/ms/**/*",
      "node_modules/node-gyp-build/**/*",
      "node_modules/qworship-ndi/**/*",
      "node_modules/grandiose/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/vosk/**/*",
      "node_modules/onnxruntime-node/**/*",
      "node_modules/smart-whisper/**/*"
    ]
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.914.0",
    "@electron/rebuild": "^3.6.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.35",
    "rcedit": "^5.0.2",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.28.0"
  }
}
