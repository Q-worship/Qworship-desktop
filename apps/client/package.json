{
  "name": "@qworship/client",
  "author": "Qworship Team",
  "description": "Qworship Desktop Client",
  "private": true,
  "version": "1.0.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:desktop": "vite",
    "build": "vite build",
    "build:desktop": "vite build && electron-builder",
    "build:bible": "node scripts/build-bible-sqlite.js",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
    "@qworship/shared": "workspace:*",
    "@qworship/types": "workspace:*",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-aspect-ratio": "^1.0.3",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-collapsible": "^1.0.3",
    "@radix-ui/react-context-menu": "^2.1.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-hover-card": "^1.0.7",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-menubar": "^1.0.4",
    "@radix-ui/react-navigation-menu": "^1.1.4",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-toggle": "^1.0.3",
    "@radix-ui/react-toggle-group": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.13.6",
    "better-sqlite3": "^9.6.0",
    "bindings": "^1.5.0",
    "canvas-txt": "^4.1.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "file-uri-to-path": "2",
    "fuse.js": "^7.3.0",
    "koffi": "^2.16.0",
    "lucide-react": "^0.320.0",
    "obs-websocket-js": "^5.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.50.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^2.2.1",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^0.8.9",
    "vosk": "^0.3.39",
    "words-to-numbers": "^1.5.1",
    "wouter": "^3.9.0",
    "zod": "^3.22.4",
    "zustand": "^5.0.0"
  },
  "build": {
    "appId": "com.qworship.desktop",
    "productName": "Qworship Desktop",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Qworship requires microphone access to use the live transcription and Hands-Free Bible voice command feature."
      }
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png"
    },
    "protocols": {
      "name": "qworship-protocol",
      "schemes": [
        "qworship"
      ]
    },
    "asarUnpack": [
      "**/node_modules/vosk/**/*",
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/koffi/**/*",
      "**/node_modules/bindings/**/*",
      "**/node_modules/file-uri-to-path/**/*",
      "dist/data/bibles/bible.db"
    ],
    "extraResources": [
      {
        "from": "assets/vosk-model",
        "to": "vosk-model",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ]
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/better-sqlite3": "^7.6.9",
    "@types/node": "^20.11.16",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.35",
    "prebuild-install": "^7.1.3",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vite-plugin-electron": "^0.28.0"
  }
}
